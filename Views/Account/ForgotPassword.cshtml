@model Electroscann_ai.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | ElectroScan AI</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', sans-serif;
                background:
                    radial-gradient(circle at top left, rgba(107, 203, 158, 0.18), transparent 20%),
                    linear-gradient(135deg, #0B2B26 0%, #0f3b33 55%, #11463c 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                animation: pageFadeIn 0.45s ease;
            }

            .forgot-container {
                max-width: 460px;
                width: 100%;
            }

            .forgot-card {
                background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(247,251,249,0.96));
                border: 1px solid rgba(255,255,255,0.58);
                border-radius: 28px;
                padding: 42px;
                box-shadow:
                    0 12px 30px rgba(2, 20, 16, 0.24),
                    0 28px 70px rgba(2, 20, 16, 0.2),
                    inset 0 1px 0 rgba(255,255,255,0.85);
                backdrop-filter: blur(12px);
            }

            .logo {
                text-align: center;
                margin-bottom: 30px;
            }

            .logo i {
                font-size: 2rem;
                color: #1F8A6B;
                margin-bottom: 14px;
                display: inline-flex;
                width: 56px;
                height: 56px;
                border-radius: 16px;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, rgba(31,138,107,0.14), rgba(107,203,158,0.18));
                box-shadow: 0 10px 24px rgba(31,138,107,0.18);
            }

            .logo h2 {
                font-family: 'Space Grotesk', sans-serif;
                font-size: 1.8rem;
                font-weight: 700;
                letter-spacing: -0.04em;
                color: #0f172a;
                margin-bottom: 6px;
            }

            .logo p {
                color: #64748B;
                font-size: 0.92rem;
            }

            .form-group {
                margin-bottom: 18px;
            }

            label {
                display: block;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.56px;
                color: #334155;
                font-weight: 700;
                margin-bottom: 8px;
            }

            input {
                width: 100%;
                padding: 12px 14px;
                border-radius: 12px;
                border: 1.5px solid #D9E4DD;
                background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(243,247,245,0.98));
                font-family: 'Inter', sans-serif;
                font-size: 0.92rem;
                color: #0F172A;
                box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
                transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
            }

            input:focus {
                outline: none;
                border-color: #1F8A6B;
                box-shadow:
                    inset 0 1px 2px rgba(15,23,42,0.05),
                    0 0 0 4px rgba(31, 138, 107, 0.14);
                transform: translateY(-1px);
            }

            .btn-submit {
                width: 100%;
                background: linear-gradient(135deg, #1F8A6B, #2ea882 58%, #6BCB9E);
                color: white;
                border: none;
                padding: 14px;
                border-radius: 14px;
                font-weight: 800;
                cursor: pointer;
                box-shadow: 0 10px 24px rgba(31,138,107,0.28);
                transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
            }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 32px rgba(31,138,107,0.34);
                filter: saturate(1.06);
            }

            .forgot-link {
                text-align: center;
                margin-top: 20px;
            }

            .forgot-link a {
                color: #1F8A6B;
                text-decoration: none;
                font-weight: 800;
            }

            .forgot-link a:hover { opacity: 0.82; }

            @@media (max-width: 520px) {
                .forgot-card { padding: 28px 20px; }
            }

            @@keyframes pageFadeIn {
                from { opacity: 0; }
                to { opacity: 1; }
            }
    </style>
</head>
<body>
    <div class="forgot-container">
        <div class="forgot-card">
            <div class="logo"><i class="fas fa-microchip" style="font-size:2rem;color:#1F8A6B;"></i><h2>Reset Password</h2><p style="color:#64748B;">Enter your email to receive reset link</p></div>
            <form asp-action="ForgotPassword" method="post">
                <div class="form-group"><label>Email Address</label><input asp-for="Email" type="email" style="width:100%;padding:12px;border-radius:16px;border:1px solid #E2E8F0;margin-top:8px;"></div>
                <button type="submit" class="btn-submit">Send Reset Link</button><div style="text-align:center;margin-top:24px;"><a href="@Url.Action("Login", "Account")" style="color:#1F8A6B;">Back to Login</a></div>            </form>
            </div>
        </div>
    </body>
</html>