<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ElectroScan AI - AI-powered electrical inspection platform for professionals, electricians and companies." />
    <title>@ViewData["Title"] - ElectroScanAI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- NAVBAR -->
    <nav class="main-navbar" id="mainNavbar">
        <a asp-action="Index" asp-controller="Home" class="nav-brand">
            <div class="nav-brand-icon"><i class="fas fa-microchip"></i></div>
            <span class="nav-brand-text">ElectroScan<span>AI</span></span>
        </a>

        <!-- Desktop Links -->
        <div class="nav-links">
            <a asp-action="Index" asp-controller="Home" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Home</a>
            <a asp-action="About" asp-controller="Home" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")">About</a>
            <a asp-action="Service" asp-controller="Home" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Service" ? "active" : "")">Services</a>

            <div class="nav-dropdown">
                <span class="nav-dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && new[] { "AI_Scanner", "Calculator", "Market_Rates", "System_Monitor" }.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "active" : "")">
                    Tools <i class="fas fa-chevron-down"></i>
                </span>
                <div class="nav-dropdown-menu">
                    <a asp-action="AI_Scanner" asp-controller="Home"><i class="fas fa-microscope"></i> AI Scanner</a>
                    <a asp-action="Calculator" asp-controller="Home"><i class="fas fa-calculator"></i> Load Calculator</a>
                    <a asp-action="Market_Rates" asp-controller="Home"><i class="fas fa-chart-bar"></i> Market Rates</a>
                    <a asp-action="System_Monitor" asp-controller="Home"><i class="fas fa-desktop"></i> System Monitor</a>
                </div>
            </div>

            <div class="nav-dropdown">
                <span class="nav-dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && new[] { "Blog", "Faq", "Careers", "Pricing" }.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "active" : "")">
                    Resources <i class="fas fa-chevron-down"></i>
                </span>
                <div class="nav-dropdown-menu">
                    <a asp-action="Blog" asp-controller="Home"><i class="fas fa-newspaper"></i> Blog</a>
                    <a asp-action="Faq" asp-controller="Home"><i class="fas fa-question-circle"></i> FAQ</a>
                    <a asp-action="Careers" asp-controller="Home"><i class="fas fa-briefcase"></i> Careers</a>
                    <a asp-action="Pricing" asp-controller="Home"><i class="fas fa-tag"></i> Pricing</a>
                </div>
            </div>

            <a asp-action="Contact" asp-controller="Home" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")">Contact</a>
        </div>

        <!-- Desktop Actions -->
        <div class="nav-actions">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="nav-user-info">
                    <div class="nav-user-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <span class="nav-user-name">@User.Identity.Name</span>
                </div>
                <form asp-action="Logout" asp-controller="Account" method="post" class="nav-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-nav-login btn-nav-logout">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </button>
                </form>
            }
            else
            {
                <a asp-action="Login" asp-controller="Account" class="btn-nav-login">Sign In</a>
                <a asp-action="Register" asp-controller="Account" class="btn-nav-cta">Get Started</a>
            }
        </div>

        <!-- Hamburger (Mobile) -->
        <div class="nav-hamburger" id="hamburger" onclick="toggleMobileNav()">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </nav>

    <!-- Mobile Nav -->
    <div class="mobile-nav" id="mobileNav">
        <a asp-action="Index" asp-controller="Home"><i class="fas fa-home"></i> Home</a>
        <a asp-action="About" asp-controller="Home"><i class="fas fa-info-circle"></i> About</a>
        <a asp-action="Service" asp-controller="Home"><i class="fas fa-cogs"></i> Services</a>
        <a asp-action="AI_Scanner" asp-controller="Home"><i class="fas fa-microscope"></i> AI Scanner</a>
        <a asp-action="Calculator" asp-controller="Home"><i class="fas fa-calculator"></i> Load Calculator</a>
        <a asp-action="Blog" asp-controller="Home"><i class="fas fa-newspaper"></i> Blog</a>
        <a asp-action="Pricing" asp-controller="Home"><i class="fas fa-tag"></i> Pricing</a>
        <a asp-action="Contact" asp-controller="Home"><i class="fas fa-envelope"></i> Contact</a>
        <div class="mobile-nav-divider"></div>
        @if (User.Identity.IsAuthenticated)
        {
            <form asp-action="Logout" asp-controller="Account" method="post" class="mobile-nav-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="mobile-nav-logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        }
        else
        {
            <a asp-action="Login" asp-controller="Account"><i class="fas fa-sign-in-alt"></i> Sign In</a>
            <a asp-action="Register" asp-controller="Account" class="mobile-nav-cta">
                <i class="fas fa-user-plus"></i> Get Started
            </a>
        }
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-grid">
                <!-- Brand -->
                <div class="footer-col">
                    <div class="footer-logo">
                        <i class="fas fa-microchip"></i>
                        <span>ElectroScan<span style="color:#1F8A6B;">AI</span></span>
                    </div>
                    <p class="footer-description">AI-driven electrical inspections for zero-risk operations. Trusted by 500+ firms across the country.</p>
                    <div class="footer-social">
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" aria-label="GitHub"><i class="fab fa-github"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>

                <!-- Company -->
                <div class="footer-col">
                    <h4>Company</h4>
                    <ul>
                        <li><a asp-action="About" asp-controller="Home">About Us</a></li>
                        <li><a asp-action="Careers" asp-controller="Home">Careers</a></li>
                        <li><a asp-action="Pricing" asp-controller="Home">Pricing</a></li>
                        <li><a asp-action="Contact" asp-controller="Home">Support</a></li>
                        <li><a asp-action="Testimonials" asp-controller="Home">Testimonials</a></li>
                    </ul>
                </div>

                <!-- Solutions -->
                <div class="footer-col">
                    <h4>Solutions</h4>
                    <ul>
                        <li><a asp-action="AI_Scanner" asp-controller="Home">AI Scanner</a></li>
                        <li><a asp-action="Calculator" asp-controller="Home">Load Calculator</a></li>
                        <li><a asp-action="Market_Rates" asp-controller="Home">Market Rates</a></li>
                        <li><a asp-action="System_Monitor" asp-controller="Home">System Monitor</a></li>
                        <li><a asp-action="Blog" asp-controller="Home">Blog</a></li>
                        <li><a asp-action="Faq" asp-controller="Home">FAQ</a></li>
                    </ul>
                </div>

                <!-- Newsletter -->
                <div class="footer-col">
                    <h4>Stay Updated</h4>
                    <p style="font-size:0.8rem;color:rgba(255,255,255,0.45);margin-bottom:0;">Get the latest AI insights and product updates.</p>
                    <div class="footer-newsletter">
                        <div class="subscribe-flex">
                            <input type="email" id="footerEmail" placeholder="Your email address">
                            <button type="button" id="footerSubscribeBtn">Go</button>
                        </div>
                    </div>
                    <div style="margin-top:20px;">
                        <h4>Legal</h4>
                        <ul>
                            <li><a asp-action="Privacy" asp-controller="Home">Privacy Policy</a></li>
                            <li><a asp-action="Terms" asp-controller="Home">Terms of Service</a></li>
                            <li><a asp-action="Cookies" asp-controller="Home">Cookie Policy</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="footer-copyright">
                    © 2026 ElectroScanAI — Smarter Scans. Safer Systems. All rights reserved.
                </div>
                <div class="footer-legal">
                    <a asp-action="Privacy" asp-controller="Home">Privacy</a>
                    <span class="sep">·</span>
                    <a asp-action="Terms" asp-controller="Home">Terms</a>
                    <span class="sep">·</span>
                    <a asp-action="Cookies" asp-controller="Home">Cookies</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Notification -->
    <div id="toastMsg" class="toast-msg">
        <i class="fas fa-check-circle"></i>
        <span id="toastText"></span>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', function () {
            const navbar = document.getElementById('mainNavbar');
            if (window.scrollY > 20) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Mobile nav toggle
        function toggleMobileNav() {
            const nav = document.getElementById('mobileNav');
            nav.classList.toggle('open');
        }

        // Footer subscribe
        document.getElementById('footerSubscribeBtn')?.addEventListener('click', function () {
            const email = document.getElementById('footerEmail').value;
            if (email && email.includes('@@')) {
                showToast('Subscribed successfully! 🎉');
                document.getElementById('footerEmail').value = '';
            } else {
                showToast('Please enter a valid email.');
            }
        });

        function showToast(msg) {
            const toast = document.getElementById('toastMsg');
            document.getElementById('toastText').textContent = msg;
            toast.style.display = 'flex';
            setTimeout(() => { toast.style.display = 'none'; }, 3500);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>