<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>@ViewBag.Title - ElectroScanAI Dashboard</title>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
</head>
<body>
    <div class="admin-container">
        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a asp-action="Index" asp-controller="Dashboard" class="logo">
                    <div class="logo-icon"><i class="fas fa-microchip"></i></div>
                    <span>ElectroScan<span style="color: var(--primary);">AI</span></span>
                </a>
            </div>
            <div class="nav-menu">
                <div class="nav-section">Main</div>
                <a asp-action="Index" asp-controller="Dashboard" class="nav-item active">
                    <i class="fas fa-tachometer-alt"></i> Dashboard Home
                </a>
                <a asp-action="User" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-users"></i> Users Management
                </a>
                <a asp-action="Electrician" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-bolt"></i> Electricians Management
                </a>
                <a asp-action="Companies" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-building"></i> Companies Management
                </a>
                <a asp-action="Jobs" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-briefcase"></i> Jobs Management
                </a>

                <div class="nav-section">Finance</div>
                <a asp-action="Subscriptions" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-credit-card"></i> Subscription Management
                </a>
                <a asp-action="Revenue" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-chart-line"></i> Revenue Reports
                </a>

                <div class="nav-section">Reports</div>
                <a asp-action="AIScans" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-microscope"></i> AI Scan Reports
                </a>
                <a asp-action="messages" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-envelope"></i> Contact Messages
                </a>

                <div class="nav-section">System</div>
                <a asp-action="Settings" asp-controller="Dashboard" class="nav-item">
                    <i class="fas fa-cog"></i> Settings
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            
            <!-- Page Content -->
            <div class="page-content">
                @RenderBody()
            </div>
        </div>
    </div>

  


</body>
</html>