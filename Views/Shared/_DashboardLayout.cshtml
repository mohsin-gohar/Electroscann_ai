<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>@ViewBag.Title - ElectroScanAI Dashboard</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>
<body>
    <!-- Sidebar Overlay (Mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a asp-action="Index" asp-controller="Dashboard" class="sidebar-logo">
                <div class="sidebar-logo-icon"><i class="fas fa-microchip"></i></div>
                <span class="sidebar-logo-text">ElectroScan<span>AI</span></span>
            </a>
        </div>

        <!-- User Info -->
        <div class="sidebar-user">
            <div class="sidebar-user-avatar">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-name">@User.Identity.Name</div>
                <div class="sidebar-user-role">
                    @if (User.IsInRole("Admin")) { <span>Administrator</span> }
                    else if (User.IsInRole("Electrician")) { <span>Electrician</span> }
                    else if (User.IsInRole("Company")) { <span>Company</span> }
                    else { <span>Client</span> }
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="nav-menu">
            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Main</div>
                <a asp-action="Index" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Dashboard" ? "active" : "")">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a asp-action="Users" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Users" ? "active" : "")">
                    <i class="fas fa-users"></i> Users Management
                </a>
                <a asp-action="Electricians" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Electricians" ? "active" : "")">
                    <i class="fas fa-bolt"></i> Electricians
                </a>
                <a asp-action="Companies" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Companies" ? "active" : "")">
                    <i class="fas fa-building"></i> Companies
                </a>
                <a asp-action="Jobs" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Jobs" ? "active" : "")">
                    <i class="fas fa-briefcase"></i> Jobs Management
                </a>

                <div class="nav-section-label">Finance</div>
                <a asp-action="Subscriptions" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Subscriptions" ? "active" : "")">
                    <i class="fas fa-credit-card"></i> Subscriptions
                </a>
                <a asp-action="Revenue" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Revenue" ? "active" : "")">
                    <i class="fas fa-chart-line"></i> Revenue Reports
                </a>

                <div class="nav-section-label">Reports</div>
                <a asp-action="AIScans" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "AIScans" ? "active" : "")">
                    <i class="fas fa-microscope"></i> AI Scan Reports
                </a>
                <a asp-action="Messages" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Messages" ? "active" : "")">
                    <i class="fas fa-envelope"></i> Contact Messages
                </a>

                <div class="nav-section-label">System</div>
                <a asp-action="Settings" asp-controller="Dashboard" class="nav-item @(ViewBag.ActivePage == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i> Settings
                </a>
            }
            else if (User.IsInRole("Electrician"))
            {
                <div class="nav-section-label">Overview</div>
                <a asp-action="Index" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "Home" ? "active" : "")">
                    <i class="fas fa-home"></i> Dashboard
                </a>
                <a asp-action="Profile" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "Profile" ? "active" : "")">
                    <i class="fas fa-user"></i> My Profile
                </a>

                <div class="nav-section-label">Jobs</div>
                <a asp-action="AvailableJobs" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "AvailableJobs" ? "active" : "")">
                    <i class="fas fa-search"></i> Available Jobs
                </a>
                <a asp-action="AppliedJobs" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "AppliedJobs" ? "active" : "")">
                    <i class="fas fa-paper-plane"></i> Applied Jobs
                </a>

                <div class="nav-section-label">Finance</div>
                <a asp-action="Earnings" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "Earnings" ? "active" : "")">
                    <i class="fas fa-wallet"></i> My Earnings
                </a>
                <a asp-action="Messages" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "Messages" ? "active" : "")">
                    <i class="fas fa-comment-dots"></i> Messages
                </a>

                <div class="nav-section-label">Account</div>
                <a asp-action="Settings" asp-controller="ElectricianDashboard" class="nav-item @(ViewBag.ActivePage == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i> Settings
                </a>
            }
            else if (User.IsInRole("Company"))
            {
                <div class="nav-section-label">Overview</div>
                <a asp-action="Index" asp-controller="CompanyDashboard" class="nav-item @(ViewBag.ActivePage == "Home" ? "active" : "")">
                    <i class="fas fa-home"></i> Dashboard
                </a>
                <a asp-action="Profile" asp-controller="CompanyDashboard" class="nav-item @(ViewBag.ActivePage == "Profile" ? "active" : "")">
                    <i class="fas fa-building"></i> Company Profile
                </a>

                <div class="nav-section-label">Jobs</div>
                <a asp-action="Jobs" asp-controller="CompanyDashboard" class="nav-item @(ViewBag.ActivePage == "Jobs" ? "active" : "")">
                    <i class="fas fa-briefcase"></i> Manage Jobs
                </a>
                <a asp-action="Applications" asp-controller="CompanyDashboard" class="nav-item @(ViewBag.ActivePage == "Applications" ? "active" : "")">
                    <i class="fas fa-file-alt"></i> Applications
                </a>

                <div class="nav-section-label">Finance</div>
                <a asp-action="Payments" asp-controller="CompanyDashboard" class="nav-item @(ViewBag.ActivePage == "Payments" ? "active" : "")">
                    <i class="fas fa-credit-card"></i> Payments
                </a>

                <div class="nav-section-label">Account</div>
                <a asp-action="Settings" asp-controller="CompanyDashboard" class="nav-item @(ViewBag.ActivePage == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i> Settings
                </a>
            }
            else
            {
                <div class="nav-section-label">Overview</div>
                <a asp-action="Index" asp-controller="ClientDashboard" class="nav-item @(ViewBag.ActivePage == "Home" ? "active" : "")">
                    <i class="fas fa-home"></i> Dashboard
                </a>
                <a asp-action="Profile" asp-controller="ClientDashboard" class="nav-item @(ViewBag.ActivePage == "Profile" ? "active" : "")">
                    <i class="fas fa-user"></i> My Profile
                </a>

                <div class="nav-section-label">Services</div>
                <a asp-action="Projects" asp-controller="ClientDashboard" class="nav-item @(ViewBag.ActivePage == "Projects" ? "active" : "")">
                    <i class="fas fa-project-diagram"></i> My Projects
                </a>
                <a asp-action="Payments" asp-controller="ClientDashboard" class="nav-item @(ViewBag.ActivePage == "Payments" ? "active" : "")">
                    <i class="fas fa-credit-card"></i> Payments
                </a>

                <div class="nav-section-label">Account</div>
                <a asp-action="Settings" asp-controller="ClientDashboard" class="nav-item @(ViewBag.ActivePage == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i> Settings
                </a>
            }
        </nav>

        <!-- Sidebar Footer: Logout -->
        <div class="sidebar-footer">
            <form asp-action="Logout" asp-controller="Account" method="post" class="sidebar-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar-logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- ===== TOP BAR ===== -->
    <header class="topbar" id="topbar">
        <div class="topbar-left">
            <button class="topbar-toggle" id="sidebarToggle" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <div class="topbar-breadcrumb">
                <a href="/" class="crumb-home"><i class="fas fa-home"></i></a>
                <span class="crumb-sep">/</span>
                <span class="crumb-current">@(ViewBag.PageTitle ?? ViewBag.Title ?? "Dashboard")</span>
            </div>
        </div>

        <div class="topbar-right">
            <button class="topbar-icon-btn" title="Notifications">
                <i class="fas fa-bell"></i>
                <span class="topbar-badge">3</span>
            </button>
            <a href="/" class="topbar-icon-btn" title="Go to Website">
                <i class="fas fa-external-link-alt"></i>
            </a>
            <div class="topbar-user">
                <div class="topbar-user-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <span class="topbar-user-name">@User.Identity.Name?.Split(' ')[0]</span>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-wrapper">
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="toast-notification" id="dashToast">
        <i class="fas fa-check-circle"></i>
        <span id="dashToastText">Action completed!</span>
    </div>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sidebar Toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        }

        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('open');
        }

        // Toast
        function showDashToast(msg, type = 'success') {
            const toast = document.getElementById('dashToast');
            document.getElementById('dashToastText').textContent = msg;
            toast.style.background = type === 'error' ? '#dc2626' : type === 'warning' ? '#d97706' : '#1F8A6B';
            toast.style.display = 'flex';
            setTimeout(() => { toast.style.display = 'none'; }, 3500);
        }

        // Modal helpers
        function openModal(id) {
            document.getElementById(id)?.classList.add('open');
        }

        function closeModal(id) {
            document.getElementById(id)?.classList.remove('open');
        }

        // Active nav item highlight
        document.querySelectorAll('.nav-item').forEach(item => {
            if (item.getAttribute('href') === window.location.pathname) {
                item.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>