@{
    Layout = "_DashboardLayout";
    ViewBag.Title = "My Projects";
    ViewBag.PageTitle = "Projects";
    ViewBag.ActivePage = "Projects";
}

<div class="page-header">
    <h1>My Projects & Service Orders</h1>
    <p>Track the progress of your scheduled electrical inspections, repairs, and compliance certifications</p>
</div>

<!-- Active Jobs & Projects Summary -->
<div class="table-card" style="margin-bottom:24px;">
    <div class="table-card-header">
        <div class="table-card-title"><i class="fas fa-tasks"></i> Active Service Orders</div>
        <button class="btn-primary-dash" onclick="location.href='/Home/Contact'"><i class="fas fa-plus"></i> Request New Inspection</button>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Project ID</th>
                <th>Service Requested</th>
                <th>Assigned Electrician</th>
                <th>Scheduled Date</th>
                <th>Progress Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="6" style="text-align:center;padding:40px;color:#9CA3AF;font-size:0.875rem;">
                    <i class="fas fa-project-diagram" style="font-size:2rem;margin-bottom:12px;display:block;color:#E2ECE9;"></i>
                    No active service projects yet. Contact our team to book an on-site expert!
                </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- History and Reports -->
<div class="table-card">
    <div class="table-card-header">
        <div class="table-card-title"><i class="fas fa-history"></i> Completed Scans & Reports History</div>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Report ID</th>
                <th>Inspection Type</th>
                <th>Inspector / AI Engine</th>
                <th>Completion Date</th>
                <th>Result Status</th>
                <th>Document</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="6" style="text-align:center;padding:30px;color:#9CA3AF;font-size:0.875rem;">
                    No report history found. Use AI Scanner to generate diagnostic reports.
                </td>
            </tr>
        </tbody>
    </table>
</div>
