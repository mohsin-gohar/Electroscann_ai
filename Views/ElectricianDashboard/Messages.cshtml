@{
    Layout = "_DashboardLayout";
    ViewBag.Title = "Messages";
    ViewBag.PageTitle = "Messages";
    ViewBag.ActivePage = "Messages";
}

<div class="page-header">
    <h1>Messages</h1>
    <p>Communicate with companies and clients</p>
</div>

<div style="display:grid; grid-template-columns: 300px 1fr; gap: 20px; height: calc(100vh - 240px);">
    <!-- Conversations List -->
    <div class="table-card" style="overflow-y:auto; display:flex; flex-direction:column;">
        <div style="padding:16px 18px; border-bottom:1px solid #E2ECE9; font-size:0.85rem; font-weight:700; color:#374151;">
            <i class="fas fa-comment-dots" style="color:#1F8A6B;margin-right:8px;"></i> Conversations
        </div>
        <div style="flex:1; overflow-y:auto;">
            @{
                var convs = new[]
                {
                    new { Name = "TechBuild Corp", Last = "We'd like to interview you tomorrow...", Time = "2h ago", Unread = 2, Active = true },
                    new { Name = "Power Systems Ltd", Last = "Application received. Thank you.", Time = "1d ago", Unread = 0, Active = false },
                    new { Name = "SafetyFirst Consulting", Last = "Can you start next Monday?", Time = "3d ago", Unread = 1, Active = false },
                    new { Name = "GreenEnergy Pvt", Last = "Thank you for applying.", Time = "1w ago", Unread = 0, Active = false },
                };
            }

            @foreach (var conv in convs)
            {
                <div style="padding:14px 18px; border-bottom:1px solid #F0F5F3; cursor:pointer; background:@(conv.Active ? "rgba(31,138,107,0.06)" : "transparent"); transition:background 0.2s;"
                     onmouseenter="this.style.background='rgba(31,138,107,0.06)'"
                     onmouseleave="this.style.background='@(conv.Active ? "rgba(31,138,107,0.06)" : "transparent")'">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="width:38px;height:38px;background:linear-gradient(135deg,#1F8A6B,#6BCB9E);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.85rem;flex-shrink:0;">
                            @conv.Name[0]
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="display:flex;align-items:center;justify-content:space-between;">
                                <span style="font-size:0.85rem;font-weight:700;color:#1E293B;">@conv.Name</span>
                                <span style="font-size:0.7rem;color:#9CA3AF;">@conv.Time</span>
                            </div>
                            <div style="font-size:0.75rem;color:#64748B;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;">@conv.Last</div>
                        </div>
                        @if (conv.Unread > 0)
                        {
                            <div style="width:18px;height:18px;background:#1F8A6B;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.65rem;font-weight:700;flex-shrink:0;">
                                @conv.Unread
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Chat Area -->
    <div class="table-card" style="display:flex; flex-direction:column;">
        <!-- Chat Header -->
        <div style="padding:16px 20px; border-bottom:1px solid #E2ECE9; display:flex; align-items:center; gap:12px;">
            <div style="width:36px;height:36px;background:linear-gradient(135deg,#1F8A6B,#6BCB9E);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.85rem;">T</div>
            <div>
                <div style="font-size:0.9rem;font-weight:700;color:#1E293B;">TechBuild Corp</div>
                <div style="font-size:0.75rem;color:#22c55e;"><i class="fas fa-circle" style="font-size:0.55rem;margin-right:4px;"></i> Online</div>
            </div>
        </div>

        <!-- Messages -->
        <div style="flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:14px;">
            <!-- Incoming -->
            <div style="display:flex; gap:10px;">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#1F8A6B,#6BCB9E);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.75rem;flex-shrink:0;align-self:flex-end;">T</div>
                <div style="max-width:70%;">
                    <div style="background:#F0F5F3;padding:12px 16px;border-radius:16px 16px 16px 4px;font-size:0.875rem;color:#1E293B;line-height:1.5;">
                        Hi! We reviewed your application and we're impressed with your profile. We'd like to schedule an interview tomorrow at 10 AM. Are you available?
                    </div>
                    <div style="font-size:0.7rem;color:#9CA3AF;margin-top:4px;padding-left:4px;">2h ago</div>
                </div>
            </div>

            <!-- Outgoing -->
            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <div style="max-width:70%;">
                    <div style="background:linear-gradient(135deg,#1F8A6B,#2ea882);padding:12px 16px;border-radius:16px 16px 4px 16px;font-size:0.875rem;color:#fff;line-height:1.5;">
                        Thank you for the positive feedback! Yes, I'm available tomorrow at 10 AM. Looking forward to the interview.
                    </div>
                    <div style="font-size:0.7rem;color:#9CA3AF;margin-top:4px;text-align:right;padding-right:4px;">1h ago</div>
                </div>
            </div>

            <!-- Incoming -->
            <div style="display:flex; gap:10px;">
                <div style="width:32px;height:32px;background:linear-gradient(135deg,#1F8A6B,#6BCB9E);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.75rem;flex-shrink:0;align-self:flex-end;">T</div>
                <div style="max-width:70%;">
                    <div style="background:#F0F5F3;padding:12px 16px;border-radius:16px 16px 16px 4px;font-size:0.875rem;color:#1E293B;line-height:1.5;">
                        We'd like to interview you tomorrow. Please bring your license and portfolio. The office is at Suite 5, Tech Tower, Lahore.
                    </div>
                    <div style="font-size:0.7rem;color:#9CA3AF;margin-top:4px;padding-left:4px;">2h ago</div>
                </div>
            </div>
        </div>

        <!-- Input -->
        <div style="padding:16px 20px; border-top:1px solid #E2ECE9; display:flex; gap:10px;">
            <input type="text" class="form-input" id="msgInput" style="margin:0;flex:1;" placeholder="Type a message...">
            <button class="btn-primary-dash" onclick="sendMsg()"><i class="fas fa-paper-plane"></i></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function sendMsg() {
        const input = document.getElementById('msgInput');
        if (input.value.trim()) {
            showDashToast('Message sent!');
            input.value = '';
        }
    }
    document.getElementById('msgInput').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') sendMsg();
    });
</script>
}
