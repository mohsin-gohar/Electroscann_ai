@{
    Layout = "_DashboardLayout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings | ElectroScan AI Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
    <script src="~/js/site.js"></script>
</head>
<body>
<div class="admin-container">

    <main class="main-content">
        <div class="top-bar"><div class="page-title"><h1>Settings</h1><p>System configuration and preferences</p></div><div class="user-menu"><button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge">4</span></button><div class="user-avatar"><i class="fas fa-user-shield"></i></div></div></div>
        <div class="stats-grid" style="grid-template-columns: 1fr;">
            <div class="stat-card"><h3>General Settings</h3><div class="form-group"><label>Site Name</label><input type="text" value="ElectroScan AI"></div><div class="form-group"><label>Admin Email</label><input type="email" value="admin@electroscan.ai"></div><div class="form-group"><label>Time Zone</label><select><option>Asia/Karachi</option><option>UTC</option></select></div><button class="btn-primary" onclick="showToast('Settings saved!')">Save Changes</button></div>
            <div class="stat-card"><h3>AI Scan Settings</h3><div class="form-group"><label>Confidence Threshold</label><input type="range" min="0" max="100" value="85"></div><div class="form-group"><label>Auto-report Generation</label><select><option>Enabled</option><option>Disabled</option></select></div><button class="btn-primary" onclick="showToast('AI Settings saved!')">Save Changes</button></div>
            <div class="stat-card"><h3>Notification Settings</h3><div class="form-group"><label><input type="checkbox"> Email Notifications</label></div><div class="form-group"><label><input type="checkbox"> Push Notifications</label></div><div class="form-group"><label><input type="checkbox"> SMS Alerts</label></div><button class="btn-primary" onclick="showToast('Notification settings saved!')">Save Changes</button></div>
        </div>
    </main>
</div>
<div id="globalToast" class="toast-msg" style="display: none;"></div>

</body>
</html>