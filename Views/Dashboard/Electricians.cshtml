@{
    Layout = "_DashboardLayout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electricians Management | ElectroScan AI Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
    <script src="~/js/site.js"></script>
</head>
<body>

    <main class="main-content">
        <div class="top-bar"><div class="page-title"><h1>Electricians Management</h1><p>Manage verified electricians</p></div><div class="user-menu"><button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge">4</span></button><div class="user-avatar"><i class="fas fa-user-shield"></i></div></div></div>

        <div class="table-card">
            <div class="table-header"><h3><i class="fas fa-bolt"></i> All Electricians</h3><button class="btn-primary" onclick="openModal('addModal')"><i class="fas fa-plus"></i> Add Electrician</button></div>
            <table class="data-table">
                <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Specialization</th><th>Experience</th><th>Rating</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    <tr><td>#EL-001</td><td>Abdul Hameed</td><td>hameed@example.com</td><td>Residential</td><td>8 years</td><td>4.8 ★</td><td><span class="status-badge status-active">Verified</span></td><td><button class="btn-success" onclick="editElectrician(1)"><i class="fas fa-edit"></i></button> <button class="btn-danger" onclick="deleteElectrician(1)"><i class="fas fa-trash"></i></button></td></tr>
                    <tr><td>#EL-002</td><td>Mohsin Raza</td><td>mohsin@example.com</td><td>Commercial</td><td>12 years</td><td>4.9 ★</td><td><span class="status-badge status-active">Verified</span></td><td><button class="btn-success" onclick="editElectrician(2)"><i class="fas fa-edit"></i></button> <button class="btn-danger" onclick="deleteElectrician(2)"><i class="fas fa-trash"></i></button></td></tr>
                    <tr><td>#EL-003</td><td>Khalid Mehmood</td><td>khalid@example.com</td><td>Industrial</td><td>15 years</td><td>4.7 ★</td><td><span class="status-badge status-pending">Pending</span></td><td><button class="btn-success" onclick="editElectrician(3)"><i class="fas fa-edit"></i></button> <button class="btn-danger" onclick="deleteElectrician(3)"><i class="fas fa-trash"></i></button></td></tr>
                </tbody>
            </table>
        </div>
    </main>
</div>

<div id="addModal" class="modal"><div class="modal-content"><div class="modal-header"><h3>Add New Electrician</h3><span onclick="closeModal('addModal')" style="cursor:pointer;">&times;</span></div><div class="modal-body"><div class="form-group"><label>Full Name</label><input type="text"></div><div class="form-group"><label>Email</label><input type="email"></div><div class="form-group"><label>Specialization</label><select><option>Residential</option><option>Commercial</option><option>Industrial</option></select></div><div class="form-group"><label>Experience (Years)</label><input type="number"></div></div><div class="modal-footer"><button class="btn-primary" onclick="addElectrician()">Add Electrician</button><button class="btn-outline" onclick="closeModal('addModal')">Cancel</button></div></div></div>
<div id="globalToast" class="toast-msg" style="display: none;"></div>

<script>
    function addElectrician() { showToast('Electrician added successfully!'); closeModal('addModal'); }
    function editElectrician(id) { showToast('Edit electrician feature'); }
    function deleteElectrician(id) { if(confirm('Delete this electrician?')) showToast('Electrician deleted'); }
</script>
</body>
</html>