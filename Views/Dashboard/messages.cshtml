@{
    Layout = "_DashboardLayout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Messages | ElectroScan AI Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
    <script src="~/js/site.js"></script>
</head>
<body>
<div class="admin-container">
    
    <main class="main-content">
        <div class="top-bar"><div class="page-title"><h1>Contact Messages</h1><p>Customer inquiries and support tickets</p></div><div class="user-menu"><button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge">4</span></button><div class="user-avatar"><i class="fas fa-user-shield"></i></div></div></div>
        <div class="table-card">
            <div class="table-header"><h3><i class="fas fa-envelope"></i> All Messages</h3><div class="search-box"><input type="text" placeholder="Search messages..."><button class="btn-primary"><i class="fas fa-search"></i></button></div></div>
            <table class="data-table">
                <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Subject</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    <tr><td>#MSG-001</td><td>Muhammad Ali</td><td>ali@example.com</td><td>Technical Support</td><td>2026-06-09</td><td><span class="status-badge status-pending">Unread</span></td><td><button class="btn-primary" style="padding:4px 12px">Reply</button></td></tr>
                    <tr><td>#MSG-002</td><td>Sarah Khan</td><td>sarah@example.com</td><td>Billing Question</td><td>2026-06-08</td><td><span class="status-badge status-active">Read</span></td><td><button class="btn-primary" style="padding:4px 12px">Reply</button></td></tr>
                </tbody>
            </table>
        </div>
    </main>
</div>

</body>
</html>