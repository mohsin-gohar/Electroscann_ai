@{
    Layout = "_DashboardLayout";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jobs Management | ElectroScan AI Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
    <script src="~/js/site.js"></script>
</head>
<body>
<div class="admin-container">
    
    <main class="main-content">
        <div class="top-bar"><div class="page-title"><h1>Jobs Management</h1><p>Manage all job postings</p></div><div class="user-menu"><button class="notification-btn"><i class="fas fa-bell"></i><span class="notification-badge">4</span></button><div class="user-avatar"><i class="fas fa-user-shield"></i></div></div></div>
        <div class="table-card">
            <div class="table-header"><h3><i class="fas fa-briefcase"></i> All Jobs</h3><button class="btn-primary" onclick="openModal('addModal')"><i class="fas fa-plus"></i> Post Job</button></div>
            <table class="data-table">
                <thead><tr><th>ID</th><th>Title</th><th>Company</th><th>Location</th><th>Type</th><th>Posted</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    <tr><td>#JOB-001</td><td>Senior Electrician</td><td>Tech Solutions</td><td>Lahore</td><td>Full Time</td><td>2026-06-01</td><td><span class="status-badge status-active">Open</span></td><td><button class="btn-success"><i class="fas fa-edit"></i></button> <button class="btn-danger"><i class="fas fa-trash"></i></button></td></tr>
                    <tr><td>#JOB-002</td><td>Electrical Engineer</td><td>Power Systems</td><td>Karachi</td><td>Contract</td><td>2026-05-28</td><td><span class="status-badge status-active">Open</span></td><td><button class="btn-success"><i class="fas fa-edit"></i></button> <button class="btn-danger"><i class="fas fa-trash"></i></button></td></tr>
                </tbody>
            </table>
        </div>
    </main>
</div>

</body>
</html>