@{
    Layout = "_DashboardLayout";
    ViewBag.Title = "Company Profile";
    ViewBag.PageTitle = "Company Profile";
    ViewBag.ActivePage = "Profile";
}

<div class="page-header">
    <h1>Company Profile 🏢</h1>
    <p>Manage your company details, branding, and contact information</p>
</div>

<div style="display:grid; grid-template-columns: 280px 1fr; gap: 24px;">
    <!-- Brand Card -->
    <div>
        <div class="form-card" style="text-align:center; padding:28px;">
            <div style="width:80px;height:80px;background:linear-gradient(135deg,#1F8A6B,#6BCB9E);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;color:#fff;font-size:2rem;">
                <i class="fas fa-building"></i>
            </div>
            <h3 style="font-size:1.1rem;font-weight:700;color:#1E293B;margin-bottom:4px;">@User.Identity.Name</h3>
            <p style="font-size:0.8rem;color:#1F8A6B;font-weight:600;margin-bottom:16px;">Electrical Contracting</p>
            <span class="badge badge-yellow" style="font-size:0.75rem;padding:6px 14px;">
                <i class="fas fa-circle" style="font-size:6px;"></i> Pending Verification
            </span>

            <div style="margin-top:20px;border-top:1px solid #E2ECE9;padding-top:16px;text-align:left;">
                <div style="font-size:0.8rem;color:#64748B;display:flex;flex-direction:column;gap:10px;">
                    <div><i class="fas fa-envelope" style="width:18px;color:#1F8A6B;"></i> @User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value</div>
                    <div><i class="fas fa-phone" style="width:18px;color:#1F8A6B;"></i> Not Provided</div>
                    <div><i class="fas fa-map-marker-alt" style="width:18px;color:#1F8A6B;"></i> Pakistan</div>
                </div>
            </div>
        </div>

        <div class="form-card" style="padding:20px;">
            <div style="font-size:0.8rem;font-weight:700;color:#374151;margin-bottom:14px;text-transform:uppercase;letter-spacing:0.5px;">Corporate Documents</div>
            <div style="display:flex;flex-direction:column;gap:10px;font-size:0.82rem;">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span style="color:#64748B;">NTN Document</span>
                    <span class="badge badge-yellow">Awaiting Upload</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span style="color:#64748B;">Incorporation Cert</span>
                    <span class="badge badge-yellow">Awaiting Upload</span>
                </div>
            </div>
            <button class="btn-outline-dash" style="width:100%;margin-top:14px;font-size:0.78rem;justify-content:center;" onclick="showDashToast('Upload dialog opened')">
                <i class="fas fa-upload"></i> Upload Documents
            </button>
        </div>
    </div>

    <!-- Edit Profile Form -->
    <div>
        <div class="form-card">
            <div style="font-size:1rem;font-weight:700;color:#1E293B;margin-bottom:20px;display:flex;align-items:center;gap:8px;">
                <i class="fas fa-edit" style="color:#1F8A6B;"></i> Edit Company Information
            </div>

            <form>
                <div class="section-label" style="font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#9CA3AF;padding:0 4px;margin-bottom:12px;display:flex;align-items:center;gap:8px; width:100%;">
                    Company Profile Details
                    <span style="flex:1;height:1px;background:#E5E7EB;display:inline-block;"></span>
                </div>

                <div class="form-grid" style="margin-bottom:20px;">
                    <div class="form-group">
                        <label class="form-label">Company Name *</label>
                        <input type="text" class="form-input" value="@User.Identity.Name" placeholder="Tech Solutions Pvt Ltd">
                    </div>
                    <div class="form-group">
                        <label class="form-label">NTN Number</label>
                        <input type="text" class="form-input" placeholder="NTN-XXXX-XXXX">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contact Person Name</label>
                        <input type="text" class="form-input" placeholder="Contact person name">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contact Email</label>
                        <input type="email" class="form-input" value="@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone Number</label>
                        <input type="tel" class="form-input" placeholder="+92 300 0000000">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Website URL</label>
                        <input type="url" class="form-input" placeholder="https://example.com">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Industry Sector</label>
                        <select class="form-select">
                            <option>Electrical Contracting</option>
                            <option>Construction</option>
                            <option>Solar Energy</option>
                            <option>Facility Management</option>
                            <option>Engineering Services</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Company Size</label>
                        <select class="form-select">
                            <option>1-10 Employees</option>
                            <option>11-50 Employees</option>
                            <option>51-200 Employees</option>
                            <option>201+ Employees</option>
                        </select>
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">Office Address</label>
                        <input type="text" class="form-input" placeholder="Full physical office address">
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label">About the Company</label>
                        <textarea class="form-input" rows="4" placeholder="Brief description of your business history, projects, and mission..."></textarea>
                    </div>
                </div>

                <div style="display:flex;gap:12px;">
                    <button type="button" class="btn-primary-dash" onclick="showDashToast('Company profile updated successfully!')">
                        <i class="fas fa-save"></i> Save Profile Details
                    </button>
                    <button type="button" class="btn-outline-dash">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
