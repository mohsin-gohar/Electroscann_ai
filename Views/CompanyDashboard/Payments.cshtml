@{
    Layout = "_DashboardLayout";
    ViewBag.Title = "Payments & Subscriptions";
    ViewBag.PageTitle = "Payments";
    ViewBag.ActivePage = "Payments";
}

<div class="page-header">
    <h1>Payments & Billing</h1>
    <p>Track your spending, subscription plans, invoices, and transaction history</p>
</div>

<!-- Subscription Card & Billing Stats -->
<div style="display:grid; grid-template-columns: 320px 1fr; gap:20px; margin-bottom:24px;">
    <!-- Active Subscription -->
    <div class="form-card" style="position:relative; overflow:hidden; border-top: 4px solid #1F8A6B;">
        <div style="font-size:0.75rem;font-weight:700;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;">Active Plan</div>
        <h2 style="font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:700;color:#1E293B;margin-bottom:6px;">Company Premium</h2>
        <p style="font-size:0.82rem;color:#64748B;margin-bottom:16px;">Access unlimited jobs posting, scanner tools & analytics</p>
        <div style="font-size:1.6rem;font-weight:700;color:#1F8A6B;margin-bottom:20px;">Rs. 5,000<span style="font-size:0.875rem;color:#64748B;font-weight:500;">/month</span></div>
        
        <div style="display:flex;flex-direction:column;gap:8px;font-size:0.8rem;color:#64748B;margin-bottom:20px;border-top:1px solid #E2ECE9;padding-top:14px;">
            <div style="display:flex;justify-content:space-between;"><span>Next Renewal:</span><strong style="color:#1E293B;">2026-08-14</strong></div>
            <div style="display:flex;justify-content:space-between;"><span>Payment Method:</span><strong style="color:#1E293B;">Visa ending in 4242</strong></div>
        </div>
        
        <button class="btn-primary-dash" style="width:100%;justify-content:center;" onclick="showDashToast('Manage billing page loading...')">
            <i class="fas fa-cog"></i> Manage Plan
        </button>
    </div>

    <!-- Stats -->
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-receipt"></i></div>
            <div class="stat-value">Rs. 15,000</div>
            <div class="stat-label">Total Spent This Year</div>
            <div class="stat-change up"><i class="fas fa-arrow-up"></i> Active Billing</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-file-invoice-dollar"></i></div>
            <div class="stat-value">0</div>
            <div class="stat-label">Pending Invoices</div>
            <div class="stat-change up"><i class="fas fa-check"></i> Account Up-to-date</div>
        </div>
    </div>
</div>

<!-- Transaction History Table -->
<div class="table-card">
    <div class="table-card-header">
        <div class="table-card-title"><i class="fas fa-history"></i> Transaction History</div>
        <button class="btn-outline-dash" onclick="showDashToast('Report downloaded!')"><i class="fas fa-download"></i> Export Statement</button>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Invoice ID</th>
                <th>Description</th>
                <th>Billing Date</th>
                <th>Amount Paid</th>
                <th>Method</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td style="font-family:monospace;font-size:0.8rem;color:#64748B;">#INV-2026-003</td>
                <td>Premium Corporate Subscription - July</td>
                <td>2026-07-14</td>
                <td><strong>Rs. 5,000</strong></td>
                <td><i class="fab fa-cc-visa" style="color:#1F8A6B;"></i> Visa</td>
                <td><span class="badge badge-green"><i class="fas fa-circle" style="font-size:6px;"></i> Paid</span></td>
                <td><button class="btn-action btn-view" title="Download Invoice" onclick="showDashToast('PDF invoice downloaded!')"><i class="fas fa-file-pdf"></i></button></td>
            </tr>
            <tr>
                <td style="font-family:monospace;font-size:0.8rem;color:#64748B;">#INV-2026-002</td>
                <td>Premium Corporate Subscription - June</td>
                <td>2026-06-14</td>
                <td><strong>Rs. 5,000</strong></td>
                <td><i class="fab fa-cc-visa" style="color:#1F8A6B;"></i> Visa</td>
                <td><span class="badge badge-green"><i class="fas fa-circle" style="font-size:6px;"></i> Paid</span></td>
                <td><button class="btn-action btn-view" title="Download Invoice" onclick="showDashToast('PDF invoice downloaded!')"><i class="fas fa-file-pdf"></i></button></td>
            </tr>
            <tr>
                <td style="font-family:monospace;font-size:0.8rem;color:#64748B;">#INV-2026-001</td>
                <td>Premium Corporate Subscription - May</td>
                <td>2026-05-14</td>
                <td><strong>Rs. 5,000</strong></td>
                <td><i class="fab fa-cc-visa" style="color:#1F8A6B;"></i> Visa</td>
                <td><span class="badge badge-green"><i class="fas fa-circle" style="font-size:6px;"></i> Paid</span></td>
                <td><button class="btn-action btn-view" title="Download Invoice" onclick="showDashToast('PDF invoice downloaded!')"><i class="fas fa-file-pdf"></i></button></td>
            </tr>
        </tbody>
    </table>
</div>
