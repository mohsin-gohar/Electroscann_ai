@{
    ViewData["Title"] = "Privacy Policy";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Privacy & Terms | ElectroScan AI — Legal Information</title>
    <!-- Google Fonts + premium typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js" defer></script>
</head>
<body>



    <main>
        <div class="legal-hero">
            <div class="container">
                <div class="hero-tag reveal"><i class="fas fa-gavel"></i> LEGAL INFORMATION</div>
                <h1 class="reveal" style="font-size: 2.8rem; font-weight: 700; letter-spacing: -0.02em;">Privacy & Terms</h1>
                <p class="reveal" style="color: #5A7568;">Learn how we protect your data and the terms that govern your use of ElectroScan AI</p>
            </div>
        </div>

        <div class="container legal-grid reveal">
            <!-- Sidebar Navigation -->
            <div class="sidebar-nav">
                <h4><i class="fas fa-file-alt" style="margin-right: 8px;"></i> Legal Documents</h4>
                <ul>
                    <li><a href="privacy.html" class="active" data-section="privacy"><i class="fas fa-lock"></i> Privacy Policy</a></li>
                    <li><a href="terms.html" data-section="terms"><i class="fas fa-file-contract"></i> Terms of Service</a></li>
                    <li><a href="security.html" data-section="security"><i class="fas fa-user-shield"></i> Security Practices</a></li>
                    <li><a href="cookies.html" data-section="cookies"><i class="fas fa-cookie-bite"></i> Cookies Policy</a></li>
                </ul>
            </div>

            <!-- Main Legal Content -->
            <div class="legal-content" id="legalContent">
                <!-- Privacy Policy Section -->
                <div id="privacy" class="legal-section">
                    <h2><i class="fas fa-lock" style="color: var(--moss); margin-right: 12px;"></i>Privacy Policy</h2>
                    <p><strong>Last Updated:</strong> January 26, 2026</p>
        
                    <h3>1. Information We Collect</h3>
                    <p>ElectroScan AI collects the following types of information to provide and improve our electrical inspection services:</p>
                    <ul>
                        <li><strong>Account Information:</strong> Name, email address, phone number, company details, and professional credentials.</li>
                        <li><strong>Scan Data:</strong> Images uploaded for AI analysis, inspection results, safety reports, and historical scan records.</li>
                        <li><strong>Usage Data:</strong> Feature interactions, calculation history, dashboard analytics, and preference settings.</li>
                        <li><strong>Technical Data:</strong> IP address, browser type, device information, and access timestamps.</li>
                    </ul>

                    <div class="highlight-box">
                        <i class="fas fa-shield-alt" style="color: var(--moss); margin-right: 12px;"></i>
                        <strong>Data Security Commitment:</strong> All electrical scan images and inspection data are encrypted at rest using AES-256 and transmitted via TLS 1.3. We never sell your personal data.
                    </div>

                    <h3>2. How We Use Your Data</h3>
                    <p>Your information is used exclusively for:</p>
                    <ul>
                        <li>Processing AI-powered electrical inspections and generating NEC-compliant reports</li>
                        <li>Improving detection accuracy and platform performance</li>
                        <li>Providing customer support and technical assistance</li>
                        <li>Sending important service updates and security notifications</li>
                    </ul>

                    <h3>3. Data Retention</h3>
                    <p>We retain scan data according to your subscription plan: Free accounts retain data for 30 days, Professional accounts for 1 year, and Enterprise accounts for 7 years or as contractually agreed. You may request data deletion at any time.</p>
                </div>

                <!-- Terms of Service Section (hidden initially) -->
                <div id="terms" class="legal-section" style="display: none;">
                    <h2><i class="fas fa-file-contract" style="color: var(--moss); margin-right: 12px;"></i>Terms of Service</h2>
                    <p><strong>Effective Date:</strong> January 26, 2026</p>
        
                    <h3>1. Acceptance of Terms</h3>
                    <p>By accessing or using ElectroScan AI's platform, website, or services, you agree to be bound by these Terms of Service. If you do not agree, please discontinue use immediately.</p>
        
                    <h3>2. License to Use</h3>
                    <p>ElectroScan AI grants you a limited, non-exclusive, non-transferable, revocable license to:</p>
                    <ul>
                        <li>Use the AI scanner for electrical inspection purposes on your own projects or client sites</li>
                        <li>Generate, download, and share safety reports</li>
                        <li>Access wire calculation, load estimation, and cost estimation tools</li>
                        <li>Store calculation history and scan records based on your subscription tier</li>
                    </ul>
        
                    <h3>3. Professional Disclaimer</h3>
                    <div class="highlight-box">
                        <i class="fas fa-exclamation-triangle" style="color: var(--electric-orange); margin-right: 12px;"></i>
                        <strong>Important:</strong> ElectroScan AI is an AI-powered diagnostic tool and does not replace certified professional electrical inspections required by law. Always consult a licensed electrician for final safety determinations and code compliance.
                    </div>
        
                    <h3>4. Prohibited Uses</h3>
                    <p>You may not:</p>
                    <ul>
                        <li>Reverse engineer, decompile, or extract source code from our AI models</li>
                        <li>Use the platform for unauthorized surveillance or illegal activities</li>
                        <li>Share your account credentials with unauthorized users</li>
                        <li>Upload malicious content or attempt to compromise platform security</li>
                    </ul>
        
                    <h3>5. Subscription & Billing</h3>
                    <p>Paid plans auto-renew monthly or annually. You may cancel anytime from account settings. Refunds are provided within 30 days of initial purchase or as required by applicable law.</p>
                </div>

                <!-- Security Practices Section -->
                <div id="security" class="legal-section" style="display: none;">
                    <h2><i class="fas fa-user-shield" style="color: var(--moss); margin-right: 12px;"></i>Security Practices</h2>
        
                    <h3>Infrastructure Security</h3>
                    <p>We maintain SOC 2 Type II certified data centers with 24/7 monitoring, intrusion detection, and redundant backups. All data is encrypted at rest using AES-256 and in transit using TLS 1.3.</p>
        
                    <h3>Account Protection</h3>
                    <ul>
                        <li>Strong password requirements (minimum 12 characters, complexity enforced)</li>
                        <li>Two-factor authentication (2FA) available for all accounts</li>
                        <li>Automatic session timeout after 30 minutes of inactivity</li>
                        <li>Email alerts for new device logins and suspicious activity</li>
                    </ul>
        
                    <h3>AI Model Privacy</h3>
                    <p>Your scan images are processed in isolated environments. By default, we do not use customer data to train our models. Enterprise customers may opt into anonymized training data sharing with explicit consent.</p>
        
                    <div class="highlight-box">
                        <i class="fas fa-check-circle" style="color: var(--moss);"></i>
                        <strong>Compliance:</strong> ElectroScan AI complies with GDPR, CCPA, and local data protection regulations. For data subject requests, contact privacy@electroscanai.com.
                    </div>
                </div>

                <!-- Cookies Policy Section -->
                <div id="cookies" class="legal-section" style="display: none;">
                    <h2><i class="fas fa-cookie-bite" style="color: var(--moss); margin-right: 12px;"></i>Cookies Policy</h2>
        
                    <h3>What Are Cookies</h3>
                    <p>Cookies are small text files stored on your device that help us remember your preferences and improve your experience.</p>
        
                    <h3>How We Use Cookies</h3>
                    <ul>
                        <li><strong>Essential Cookies:</strong> Required for authentication, session management, and platform security</li>
                        <li><strong>Preference Cookies:</strong> Remember your language, theme, and calculator settings</li>
                        <li><strong>Analytics Cookies:</strong> Help us understand platform usage and improve features (anonymous aggregate data)</li>
                        <li><strong>Functionality Cookies:</strong> Store recently used calculations and scan history for convenience</li>
                    </ul>
        
                    <h3>Managing Cookies</h3>
                    <p>You can control cookies through your browser settings. However, disabling essential cookies may affect platform functionality. We do not use tracking cookies for advertising or cross-site tracking.</p>
        
                    <p><strong>Contact:</strong> For any privacy-related inquiries, reach us at <a href="mailto:privacy@electroscanai.com" style="color: var(--moss);">privacy@electroscanai.com</a> or call +1 (522) 605-6148.</p>
                </div>
            </div>
        </div>
    </main>



</body>
</html>