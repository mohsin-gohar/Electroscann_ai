<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>ElectroScan AI | Live Interactive Demo — AI Electrical Compliance Platform</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  
</head>
<body>

<main>
  <!-- Hero Section -->
  <div class="demo-hero">
    <div class="container">
      <div class="hero-badge">
        <i class="fas fa-flask"></i> LIVE INTERACTIVE DEMO
      </div>
      <h1>Experience <span>AI Electrical Intelligence</span></h1>
      <p>Real-time wire tracking, drag-and-drop analysis, and risk assessment — no signup required.</p>
    </div>
  </div>

  <div class="container">
    <div class="demo-grid">
      
      <!-- LEFT: Camera Viewport Simulation -->
      <div class="glass-card">
        <div class="card-header">
          <h3><i class="fas fa-camera"></i> Live Wire Tracking</h3>
          <p>AI-powered real-time detection simulation</p>
        </div>
        <div class="card-body">
          <div class="camera-viewport">
            <div class="scan-frame">
              <div class="scan-line"></div>
              <div class="wire-tracking-dots">
                <div class="track-dot" style="top: 30%; left: 45%;"></div>
                <div class="track-dot" style="top: 55%; left: 60%; animation-delay: 0.5s;"></div>
                <div class="track-dot" style="top: 70%; left: 35%; animation-delay: 1s;"></div>
              </div>
            </div>
            <div class="camera-overlay">
              <div class="camera-placeholder" id="cameraPlaceholder">
                <i class="fas fa-camera"></i>
                <p>Ready to scan</p>
              </div>
            </div>
          </div>
          
          <div class="btn-group">
            <button class="btn-primary" id="startScanBtn"><i class="fas fa-play"></i> Start AI Scan</button>
            <button class="btn-outline" id="resetCameraBtn"><i class="fas fa-sync-alt"></i> Reset</button>
          </div>
          
          <div id="scanResultArea"></div>
        </div>
      </div>
      
      <!-- RIGHT: Drag & Drop Upload Zone -->
      <div class="glass-card">
        <div class="card-header">
          <h3><i class="fas fa-cloud-upload-alt"></i> Image Analysis</h3>
          <p>Drag & drop or click to upload</p>
        </div>
        <div class="card-body">
          <div class="upload-zone-premium" id="uploadZone">
            <div class="upload-icon"><i class="fas fa-images"></i></div>
            <p>Click or drag & drop an image</p>
            <p class="small">JPG, PNG, WEBP (Demo simulation)</p>
            <input type="file" id="fileInput" accept="image/jpeg,image/png,image/webp" style="display: none;">
          </div>
          
          <div class="image-preview" id="imagePreview">
            <img id="previewImg" alt="Preview">
            <div class="progress-bar-premium"><div class="progress-fill" id="uploadProgress"></div></div>
          </div>
          
          <div id="uploadResultArea"></div>
          
          <div style="margin-top: 16px;">
            <button class="btn-outline" id="sampleImageBtn" style="width: 100%;"><i class="fas fa-image"></i> Use Sample Image</button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Wire Tester Row (Full Width) -->
    <div class="glass-card" style="margin-bottom: 32px;">
      <div class="card-header">
        <h3><i class="fas fa-microchip"></i> Interactive Wire Tester</h3>
        <p>Select a wire type to simulate AI detection</p>
      </div>
      <div class="card-body">
        <div class="wire-badge-group">
          <div class="wire-badge" data-wire="phase"><i class="fas fa-bolt"></i> Phase Wire</div>
          <div class="wire-badge" data-wire="neutral"><i class="fas fa-minus-circle"></i> Neutral Wire</div>
          <div class="wire-badge" data-wire="faulty"><i class="fas fa-exclamation-triangle"></i> Faulty Wire</div>
          <div class="wire-badge" data-wire="burned"><i class="fas fa-fire"></i> Burned Wire</div>
        </div>
        <div id="wireTestResult" style="background: var(--slate-100); border-radius: 24px; padding: 24px; text-align: center; min-height: 100px;">
          <p class="small" style="color: var(--slate-400);">Click any wire type above</p>
        </div>
      </div>
    </div>
    
    <!-- Risk Calculator Slider -->
    <div class="glass-card">
      <div class="card-header">
        <h3><i class="fas fa-chart-line"></i> Risk Assessment Simulator</h3>
        <p>Adjust the slider to see AI risk recommendations</p>
      </div>
      <div class="card-body">
        <div class="risk-slider-container">
          <label>Risk Level</label>
          <input type="range" id="riskSlider" min="0" max="100" value="25">
          <div class="risk-value" id="riskValue">Current Risk: <span class="risk-low">25% (Low)</span></div>
        </div>
        <div class="progress-bar-premium" style="height: 8px;">
          <div class="progress-fill" id="riskMeter" style="width: 25%; background: linear-gradient(90deg, #22C55E, #F59E0B, #DC2626);"></div>
        </div>
        <div class="safety-recommendation" id="safetyRecommendation">
          <i class="fas fa-check-circle" style="color: #22C55E;"></i>
          <span>System appears safe. Regular maintenance recommended.</span>
        </div>
      </div>
    </div>
  </div>
</main>

<div class="toast-premium" id="toast">
  <i class="fas fa-check-circle"></i>
  <span id="toastMsg">Message</span>
</div>


</body>
</html>