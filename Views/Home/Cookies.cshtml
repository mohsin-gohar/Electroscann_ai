@{
    ViewData["Title"] = "Cookie Policy";
}

<div style="background: linear-gradient(135deg, #0B2B26 0%, #145C4E 100%); padding: 80px 24px; text-align: center; color: white;">
    <div style="max-width: 800px; margin: 0 auto;">
        <h1 style="font-family: 'Space Grotesk', sans-serif; font-size: 3rem; font-weight: 700; margin-bottom: 16px;">Cookie Policy</h1>
        <p style="font-size: 1.1rem; color: rgba(255,255,255,0.7); margin: 0;">Last Updated: July 14, 2026</p>
    </div>
</div>

<div style="max-width: 800px; margin: 60px auto; padding: 0 24px; color: #1E293B; line-height: 1.8;">
    <div class="card-body" style="background: white; border-radius: 24px; padding: 40px; border: 1px solid #E2ECE9; box-shadow: 0 10px 30px rgba(31,138,107,0.05);">
        
        <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700; color: #0B2B26; margin-bottom: 16px;">1. What Are Cookies</h2>
        <p style="margin-bottom: 24px;">Cookies are tiny text files stored on your computer or mobile device when you browse our site. They help us remember your configuration settings, authenticate logins, and target performance improvements.</p>

        <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700; color: #0B2B26; margin-bottom: 16px;">2. How We Use Cookies</h2>
        <p style="margin-bottom: 24px;">We use essential security cookies to track authorized sessions across dashboards, preferences cookies to retain configuration settings (like timezone/language), and analytical cookies to improve AI load scanning operations.</p>

        <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700; color: #0B2B26; margin-bottom: 16px;">3. Managing Your Cookies</h2>
        <p style="margin-bottom: 24px;">You can configure your browser to reject all cookies or notify you when a cookie is placed. Note that turning off essential cookies will disable access to dashboard sections.</p>

    </div>
</div>
