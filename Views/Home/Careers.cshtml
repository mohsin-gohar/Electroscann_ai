<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Careers | ElectroScan AI — Join the AI Revolution in Electrical Safety</title>
  <!-- Google Fonts + premium typography -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
 <link rel="stylesheet" href="electroscann-ai.css" />
 <script src="electroscann-ai.js" defer></script>
</head>
<body>


<main>
  <div class="careers-hero">
    <div class="container">
      <div class="hero-tag reveal"><i class="fas fa-rocket"></i> JOIN THE TEAM</div>
      <h1 class="reveal" style="font-size: 3rem; font-weight: 700; letter-spacing: -0.02em;">Shape the future of<br>electrical safety</h1>
      <p class="reveal" style="color: #5A7568; max-width: 550px; margin: 16px auto 0;">We're building an AI-powered platform that's transforming electrical inspections worldwide. Join us and make an impact.</p>
      <div class="reveal" style="margin-top: 32px;">
        <a href="#openings" class="btn-premium btn-green"><i class="fas fa-briefcase"></i> View Open Positions</a>
      </div>
    </div>
  </div>

  <!-- Benefits Section -->
  <div class="container benefits-section reveal">
    <div style="text-align: center; margin-bottom: 48px;">
      <span style="color: var(--moss); font-weight: 600;">WHY JOIN US</span>
      <h2 style="font-size: 2rem; margin-top: 8px;">Benefits & perks</h2>
    </div>
    <div class="benefits-grid">
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-rocket"></i></div>
        <h4>Innovation First</h4>
        <p>Work on cutting-edge AI & computer vision technology that's changing the electrical industry.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-dollar-sign"></i></div>
        <h4>Competitive Pay</h4>
        <p>Top-tier salaries, equity options, and performance bonuses for all team members.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-laptop-house"></i></div>
        <h4>Remote Friendly</h4>
        <p>Work from anywhere with flexible hours and async-first collaboration.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-heartbeat"></i></div>
        <h4>Health & Wellness</h4>
        <p>Comprehensive health, dental, vision coverage and mental health support.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-graduation-cap"></i></div>
        <h4>Learning Budget</h4>
        <p>$5,000 annual budget for courses, conferences, and professional development.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-calendar-alt"></i></div>
        <h4>Unlimited PTO</h4>
        <p>Take time off when you need it. We trust our team to deliver results.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-users"></i></div>
        <h4>Great Team</h4>
        <p>Work with talented engineers, researchers, and designers from around the world.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon"><i class="fas fa-globe"></i></div>
        <h4>Global Impact</h4>
        <p>Make buildings safer around the world with technology that saves lives.</p>
      </div>
    </div>
  </div>

  <!-- Culture Section -->
  <div class="container culture-section reveal">
    <div class="culture-grid">
      <div class="culture-image">
        <img src="~/Image/careers.png" alt="creers culture" style="width:100%; border-radius: 32px; box-shadow: 0 12px 24px -8px rgba(0,0,0,0.1);" />
        <p style="margin-top: 20px; color: var(--moss); font-weight: 500;">AI Innovation Lab</p>
      </div>
      <div class="culture-content">
        <h2 style="font-size: 1.8rem;">Our culture</h2>
        <p style="color: var(--text-muted); line-height: 1.7;">At ElectroScan AI, we're pushing the boundaries of what's possible with deep learning and electrical engineering. Our team includes experts from top AI labs and electrical safety institutions.</p>
        <ul class="culture-list">
          <li><i class="fas fa-check-circle"></i> Move fast, ship quality, iterate rapidly</li>
          <li><i class="fas fa-check-circle"></i> Data-driven decisions with customer focus</li>
          <li><i class="fas fa-check-circle"></i> Continuous learning and technical growth</li>
          <li><i class="fas fa-check-circle"></i> Work-life balance and sustainable pace</li>
          <li><i class="fas fa-check-circle"></i> Diversity, inclusion, and belonging</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Job Openings -->
  <div class="container jobs-section reveal" id="openings">
    <div style="text-align: center; margin-bottom: 48px;">
      <span style="color: var(--moss); font-weight: 600;">OPPORTUNITIES</span>
      <h2 style="font-size: 2rem;">Open positions</h2>
      <p style="color: var(--text-muted);">Join us in building the future of electrical inspections</p>
    </div>

    <div class="job-card">
      <div class="job-info">
        <h3>Senior Machine Learning Engineer</h3>
        <div class="job-meta">
          <span><i class="fas fa-map-marker-alt"></i> Remote (Global)</span>
          <span><i class="fas fa-clock"></i> Full-time</span>
          <span><i class="fas fa-dollar-sign"></i> $150k - $200k</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <span class="job-badge">AI Team</span>
        <button class="apply-btn" data-job="Senior ML Engineer">Apply →</button>
      </div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <h3>Computer Vision Researcher</h3>
        <div class="job-meta">
          <span><i class="fas fa-map-marker-alt"></i> San Francisco / Remote</span>
          <span><i class="fas fa-clock"></i> Full-time</span>
          <span><i class="fas fa-dollar-sign"></i> $140k - $180k</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <span class="job-badge">Research</span>
        <button class="apply-btn" data-job="Computer Vision Researcher">Apply →</button>
      </div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <h3>Full Stack Developer (React + Python)</h3>
        <div class="job-meta">
          <span><i class="fas fa-map-marker-alt"></i> Remote</span>
          <span><i class="fas fa-clock"></i> Full-time</span>
          <span><i class="fas fa-dollar-sign"></i> $120k - $160k</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <span class="job-badge">Engineering</span>
        <button class="apply-btn" data-job="Full Stack Developer">Apply →</button>
      </div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <h3>Electrical Safety Consultant (NEC Expert)</h3>
        <div class="job-meta">
          <span><i class="fas fa-map-marker-alt"></i> Remote (US)</span>
          <span><i class="fas fa-clock"></i> Contract / Part-time</span>
          <span><i class="fas fa-dollar-sign"></i> $100 - $150/hr</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <span class="job-badge">Domain Expert</span>
        <button class="apply-btn" data-job="Electrical Safety Consultant">Apply →</button>
      </div>
    </div>

    <div class="job-card">
      <div class="job-info">
        <h3>Product Designer (UI/UX)</h3>
        <div class="job-meta">
          <span><i class="fas fa-map-marker-alt"></i> Remote</span>
          <span><i class="fas fa-clock"></i> Full-time</span>
          <span><i class="fas fa-dollar-sign"></i> $110k - $150k</span>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 16px;">
        <span class="job-badge">Design</span>
        <button class="apply-btn" data-job="Product Designer">Apply →</button>
      </div>
    </div>
  </div>

  <!-- CTA Join -->
  <div class="container cta-join reveal">
    <i class="fas fa-envelope-open-text" style="font-size: 2.5rem; color: var(--mint); margin-bottom: 16px; display: inline-block;"></i>
    <h2 style="font-size: 1.8rem;">Don't see the perfect role?</h2>
    <p style="margin: 16px auto; max-width: 480px; opacity: 0.9;">We're always looking for exceptional talent. Send us your resume and we'll reach out when something matches.</p>
    <button class="btn-premium" style="background: white; color: var(--pine);" id="speculativeBtn"><i class="fas fa-paper-plane"></i> Submit General Application</button>
  </div>
</main>

<div id="toastMsg" class="toast-msg">
  <i class="fas fa-check-circle" style="color: var(--electric-green);"></i>
  <span id="toastText">Application submitted</span>
</div>

</body>
</html>