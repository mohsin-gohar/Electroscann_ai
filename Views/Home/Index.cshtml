@{
    ViewData["Title"] = "Home Page";
}
    <main>
        <section class="hero">
            <div class="container">
                <div class="hero-grid">
                    <div class="hero-left reveal">
                        <div class="hero-badge">AI Safety Intelligence</div>
                        <h1>Smarter Scans.<br>Safer Systems.</h1>
                        <p>ElectroScan AI uses advanced artificial intelligence to detect, assess, calculate loads and generate compliant reports — faster and more accurately.</p>
                        <div class="hero-actions">
                            <a asp-action="Demo" asp-controller="Home" class="btn-premium"><i class="fas fa-play-circle"></i> Watch Demo</a>
                            <a asp-action="Service" asp-controller="Home" class="btn-premium btn-outline-premium"><i class="fas fa-chart-line"></i> Explore Services</a>
                        </div>
                        <div class="hero-stats">
                            <div class="stat-block"><h3>98%</h3><span>Faster reporting</span></div>
                            <div class="stat-block"><h3>24/7</h3><span>AI scanning</span></div>
                            <div class="stat-block"><h3>NEC+</h3><span>Certified reports</span></div>
                        </div>
                    </div>
                    <div class="image-right">
                        <div class="card-container">
                            <img src="~/image/homeheader.jpg" alt="ElectroScan AI Diagnostics">
                            <div class="card-caption">
                                <i class="fas fa-circle"></i>
                                Intelligent diagnostics · Real-time analytics
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="container pillars reveal">
            <div class="section-heading">
                <div class="section-eyebrow"><i class="fas fa-bolt"></i> Core Advantages</div>
                <h2 class="section-title">Built for electrical precision</h2>
                <p class="section-subtitle">From inspection to compliance, every workflow is designed to shorten analysis time and increase confidence on-site.</p>
            </div>
            <div class="pillars-grid">
                <div class="pillar-card">
                    <div class="pillar-icon"><i class="fas fa-eye"></i></div>
                    <h3>AI-Powered Detection</h3>
                    <p>Advanced computer vision identifies thermal anomalies, arc faults, and loose connections with 99% accuracy.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="ai-detection">Learn More →</a>
                </div>
                <div class="pillar-card">
                    <div class="pillar-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3>Enhance Safety & Compliance</h3>
                    <p>Automated NEC/NFPA reporting, risk mitigation, and real-time compliance dashboards for facility managers.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="safety-compliance">Learn More →</a>
                </div>
                <div class="pillar-card">
                    <div class="pillar-icon"><i class="fas fa-clock"></i></div>
                    <h3>Save Time & Reduce Risk</h3>
                    <p>Cut inspection time by 70% while improving fault detection — intelligent load calculations prevent overloads.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="time-risk">Learn More →</a>
                </div>
            </div>
        </section>

        <section class="container about-luxury reveal home-about-section">
            <div class="about-flex">
                <div class="about-text">
                    <span class="section-eyebrow">About Us</span>
                    <h2>Intelligence That Powers <span style="color:#1F8A6B;">Electrical Safety</span></h2>
                    <p>ElectroScan AI is built for electrical professionals, contractors, and facility managers who demand accuracy, speed, and compliance. Our AI-driven platform simplifies complex electrical inspections and reporting.</p>
                    <div class="feature-check-grid">
                        <div class="feature-check"><i class="fas fa-check-circle"></i> AI-Powered issue Detection</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Reduce Downtime & Risk</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Accurate Load Calculations</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Improve Operational Safety</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> NEC Compliant Reports</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Cloud-Based & Secure</div>
                    </div>
                    <a asp-action="About" asp-controller="Home" class="btn-premium btn-outline-premium">Learn More About Us →</a>
                </div>
                <div class="stat-card-soft">
                    <i class="fas fa-charging-station"></i>
                    <h3>Trusted by 500+ firms</h3>
                    <p>Real-time AI analytics · 24/7 monitoring · Secure</p>
                </div>
            </div>
        </section>

        <section class="container services-showcase reveal">
            <div class="section-heading">
                <div class="section-eyebrow"><i class="fas fa-layer-group"></i> Smart Solutions</div>
                <h2 class="section-title">For Electrical Professionals</h2>
            </div>
            <div class="feature-rail">
                <div class="feature-pill">AI Scan</div>
                <div class="feature-pill">Load Calculation</div>
                <div class="feature-pill">Safety Reports</div>
                <div class="feature-pill">Compliance Analytics</div>
            </div>
            <div class="showcase-grid home-showcase-grid">
                <div class="showcase-card">
                    <div class="icon-wrap"><i class="fas fa-microscope"></i></div>
                    <h3>AI Scan</h3>
                    <p>Advanced AI detects exact anomalies, potential failures in real-time — predictive maintenance insights.</p>
                    <a asp-action="AI_Scanner" asp-controller="Home" class="btn-premium">Learn More →</a>
                </div>
                <div class="showcase-card">
                    <div class="icon-wrap"><i class="fas fa-weight-hanging"></i></div>
                    <h3>Load Calculation</h3>
                    <p>Accurate load calculations ensure system reliability, prevent overloads, and optimize performance.</p>
                    <a asp-action="Calculator" asp-controller="Home" class="btn-premium">Learn More →</a>
                </div>
                <div class="showcase-card">
                    <div class="icon-wrap"><i class="fas fa-file-signature"></i></div>
                    <h3>Safety Reports</h3>
                    <p>Generate NEC-compliant reports with intensity & actionable safety recommendations in seconds.</p>
                    <a asp-action="AI_Scanner" asp-controller="Home" class="btn-premium">Learn More →</a>
                </div>
            </div>
        </section>

        <section class="container reveal">
            <div class="section-heading">
                <div class="section-eyebrow"><i class="fas fa-star"></i> Outcomes</div>
                <h2 class="section-title">Clients love the confidence it brings</h2>
            </div>
            <div class="testimonial-grid">
                <div class="testimonial-card">
                    <div class="testimonial-rating">★★★★★</div>
                    <h3>Faster field decisions</h3>
                    <p>“Before ElectroScan AI, we spent hours validating reports. Now our field team moves with confidence and speed.”</p>
                </div>
                <div class="testimonial-card">
                    <div class="testimonial-rating">★★★★★</div>
                    <h3>Clearer compliance</h3>
                    <p>“The risk summaries and recommendations are easy to hand over to clients and internal stakeholders.”</p>
                </div>
                <div class="testimonial-card">
                    <div class="testimonial-rating">★★★★★</div>
                    <h3>More reliable oversight</h3>
                    <p>“We can identify probable risks earlier without adding friction to the inspection process.”</p>
                </div>
            </div>
        </section>

        <section class="container reveal">
            <div class="section-heading">
                <div class="section-eyebrow"><i class="fas fa-dollar-sign"></i> Pricing</div>
                <h2 class="section-title">Choose your plan</h2>
                <p class="section-subtitle">A premium operating model for small teams, growing service companies, and larger inspection programs.</p>
            </div>
            <div class="pricing-grid">
                <div class="pricing-card">
                    <div class="icon-wrap"><i class="fas fa-seedling"></i></div>
                    <h3>Starter</h3>
                    <div class="plan-price">$29 <span>/ month</span></div>
                    <p>Best for individual consultants and early-stage inspection workflows.</p>
                    <ul class="feature-list">
                        <li><i class="fas fa-check-circle"></i> 10 AI scans</li>
                        <li><i class="fas fa-check-circle"></i> Basic report generation</li>
                        <li><i class="fas fa-check-circle"></i> Standard analytics</li>
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn-premium btn-outline-premium">Get Started</a>
                </div>
                <div class="pricing-card featured">
                    <div class="featured-badge">Most Popular</div>
                    <div class="icon-wrap"><i class="fas fa-rocket"></i></div>
                    <h3>Growth</h3>
                    <div class="plan-price">$79 <span>/ month</span></div>
                    <p>For service teams that need advanced diagnostics, faster turnaround, and collaboration.</p>
                    <ul class="feature-list">
                        <li><i class="fas fa-check-circle"></i> Unlimited AI scans</li>
                        <li><i class="fas fa-check-circle"></i> Team dashboards</li>
                        <li><i class="fas fa-check-circle"></i> Priority support</li>
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn-premium">Choose Growth</a>
                </div>
                <div class="pricing-card">
                    <div class="icon-wrap"><i class="fas fa-building"></i></div>
                    <h3>Enterprise</h3>
                    <div class="plan-price">Custom <span>scaling</span></div>
                    <p>Built for large portfolios and coordinated multi-site electrical operations.</p>
                    <ul class="feature-list">
                        <li><i class="fas fa-check-circle"></i> Advanced workflows</li>
                        <li><i class="fas fa-check-circle"></i> White-label controls</li>
                        <li><i class="fas fa-check-circle"></i> Dedicated onboarding</li>
                    </ul>
                    <a asp-controller="Home" asp-action="Contact" class="btn-premium btn-outline-premium">Talk to Sales</a>
                </div>
            </div>
        </section>

        <section class="container contact-premium reveal">
            <div class="contact-grid">
                <div class="contact-left">
                    <h2>Let’s Talk</h2>
                    <p>Have a question or want to schedule a demo? We’re here to help.</p>
                    <div class="contact-details">
                        <div class="detail-row"><i class="fas fa-map-marker-alt"></i> Suite 460, Houston, TX 77024</div>
                        <div class="detail-row"><i class="fas fa-phone-alt"></i> +1 (522) 605-6148</div>
                        <div class="detail-row"><i class="fas fa-envelope"></i> hello@electroscanai.com</div>
                    </div>
                    <div class="chat-badge">
                        <i class="fas fa-comment-dots"></i> Live Chat · We’re Online <i class="fas fa-circle"></i>
                    </div>
                    <p><i class="fas fa-clock"></i> Support: Mon-Fri 8am - 7pm CST</p>
                </div>
                <div class="contact-right">
                    <form id="luxuryContactForm">
                        <div class="input-group"><input type="text" placeholder="Your Name" id="name" required></div>
                        <div class="input-group"><input type="email" placeholder="Your Email" id="email" required></div>
                        <div class="input-group"><input type="tel" placeholder="Phone Number" id="phone"></div>
                        <div class="input-group"><input type="text" placeholder="Company / Organization"></div>
                        <div class="input-group"><textarea rows="3" placeholder="Your Message" id="msg"></textarea></div>
                        <button type="submit" class="btn-premium"><i class="fas fa-paper-plane"></i> Send Message</button>
                    </form>
                    <p class="tiny-copy">We’ll get back within 24 hours</p>
                </div>
            </div>
        </section>

        <section class="container reveal newsletter-wrap">
            <div class="newsletter-card">
                <h3>Stay Updated with ElectroScan AI</h3>
                <p>Get the latest AI electrical insights, case studies, and product updates.</p>
                <div class="newsletter-form">
                    <input type="email" id="newsEmail" placeholder="Your email address">
                    <button id="subscribeNewsBtn" class="btn-premium">Subscribe</button>
                </div>
            </div>
        </section>
    </main>