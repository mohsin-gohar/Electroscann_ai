@{
    ViewData["Title"] = "Home Page";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>ElectroScan AI | Intelligence that powers electrical safety</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css"/>
    
    <script src="~/js/site.js" defer></script>
</head>
<body>

    <main>
        <div class="hero">
            <div class="container">
                <div class="hero-grid">
                    <div class="hero-left reveal">

                        <h1>Smarter Scans.<br>Safer Systems.</h1>
                        <p>ElectroScan AI uses advanced artificial intelligence to detect, assess, calculate loads and generate compliant reports — faster and more accurately.</p>
                        <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                            <a asp-action="Demo" asp-controller="Home" class="btn-premium"><i class="fas fa-play-circle"></i> Watch Demo</a>
                            <a asp-action="Service" asp-controller="Home" class="btn-premium btn-outline-premium"><i class="fas fa-chart-line"></i> Explore Services</a>
                        </div>
                        <div class="hero-stats">
                            <div class="stat-block"><h3>98%</h3><span style="color:#4B6B5E;">Faster reporting</span></div>
                            <div class="stat-block"><h3>24/7</h3><span style="color:#4B6B5E;">AI scanning</span></div>
                            <div class="stat-block"><h3>NEC+</h3><span style="color:#4B6B5E;">Certified reports</span></div>
                        </div>
                    </div>
                    <div class="image-right">
                        <div class="card-container">
                            <img src="~/image/homeheader.jpg" alt="ElectroScan AI Diagnostics">
                            <div class="card-caption">
                                <i class="fas fa-circle" style="color: #6BCB9E; font-size: 0.5rem; margin-right: 5px;"></i>
                                Intelligent diagnostics · Real-time analytics
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container pillars reveal">
            <div class="pillars-grid">
                <div class="pillar-card">
                    <div class="pillar-icon"><i class="fas fa-eye"></i></div>
                    <h3>AI-Powered Detection</h3>
                    <p>Advanced computer vision identifies thermal anomalies, arc faults, and loose connections with 99% accuracy.</p>
                    <a asp-action="Services" asp-controller="Home" asp-fragment="ai-detection" style="color:#1F8A6B; text-decoration:none; font-weight:600;">Learn More →</a>
                </div>
                <div class="pillar-card">
                    <div class="pillar-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3>Enhance Safety & Compliance</h3>
                    <p>Automated NEC/NFPA reporting, risk mitigation, and real-time compliance dashboards for facility managers.</p>
                    <a asp-action="Services" asp-controller="Home" asp-fragment="safety-compliance" style="color:#1F8A6B; text-decoration:none; font-weight:600;">Learn More →</a>
                </div>
                <div class="pillar-card">
                    <div class="pillar-icon"><i class="fas fa-clock"></i></div>
                    <h3>Save Time & Reduce Risk</h3>
                    <p>Cut inspection time by 70% while improving fault detection — intelligent load calculations prevent overloads.</p>
                    <a asp-action="Services" asp-controller="Home" asp-fragment="time-risk"  style="color:#1F8A6B; text-decoration:none; font-weight:600;">Learn More →</a>
                </div>
            </div>
        </div>

        <div class="container about-luxury reveal" style="margin-top:50px;text-align:center;">
            <div class="about-flex">
                <div class="about-text">
                    <span style="color:#1F8A6B; font-weight:600; letter-spacing:1px; text-align:center; ">ABOUT US</span>
                    <h2>Intelligence That Powers <span style="color:#1F8A6B;">Electrical Safety</span></h2>
                    <p style="color:#2C3A33;">ElectroScan AI is built for electrical professionals, contractors, and facility managers who demand accuracy, speed, and compliance. Our AI-driven platform simplifies complex electrical inspections and reporting.</p>
                    <div class="feature-check-grid">
                        <div class="feature-check"><i class="fas fa-check-circle"></i> AI-Powered issue Detection</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Reduce Downtime & Risk</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Accurate Load Calculations</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Improve Operational Safety</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> NEC Compliant Reports</div>
                        <div class="feature-check"><i class="fas fa-check-circle"></i> Cloud-Based & Secure</div>
                    </div>
                    <a asp-action="About" asp-controller="Home" class="btn-premium btn-outline-premium" style="padding:12px 30px;">Learn More About Us →</a>
                </div>
                <div style="flex:0.8; background: linear-gradient(145deg, #EAF7F1, white); border-radius: 36px; padding: 32px; text-align:center;">
                    <i class="fas fa-charging-station" style="font-size: 5rem; color:#1F8A6B;"></i>
                    <h3 style="margin:20px 0 10px;">Trusted by 500+ firms</h3>
                    <p>Real-time AI analytics · 24/7 monitoring · Secure</p>
                </div>
            </div>
        </div>

        <div class="container services-showcase reveal">
            <div style="text-align:center; margin-top: 48px;">
                <span style="color:#1F8A6B; font-weight:600;">SMART SOLUTIONS</span>
                <h2 style="font-size: 2.2rem;">For Electrical Professionals</h2>
            </div>
            <div class="service-cards">
                <div class="service-card-modern">
                    <div class="service-icon-lg"><i class="fas fa-microscope"></i></div>
                    <h3>AI Scan</h3>
                    <p>Advanced AI detects exact anomalies, potential failures in real-time — predictive maintenance insights.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="Service#Ai-Scan"  class="btn-premium" style="margin-top: 20px; display: inline-block; padding:10px 24px;">Learn More →</a>
                </div>
                
                <div class="service-card-modern">
                    <div class="service-icon-lg"><i class="fas fa-weight-hanging"></i></div>
                    <h3>Load Calculation</h3>
                    <p>Accurate load calculations ensure system reliability, prevent overloads, and optimize performance.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="Service#load-calculation" class="btn-premium" style="margin-top: 20px; display: inline-block; padding:10px 24px;">Learn More →</a>
                </div>
                
                <div class="service-card-modern">
                    <div class="service-icon-lg"><i class="fas fa-file-signature"></i></div>
                    <h3>Safety Reports</h3>
                    <p>Generate NEC-compliant reports with intensity & actionable safety recommendations in seconds.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="Service#safety-reports" class="btn-premium" style="margin-top: 20px; display: inline-block; padding:10px 24px;">Learn More →</a>
                </div>
            </div>
        </div>

        <div class="container contact-premium reveal">
            <div class="contact-grid">
                <div class="contact-left">
                    <h2 style="margin-top:50px;"> Let's Talk</h2>
                    <p style="color:#BEDBD5;">Have a question or want to schedule a demo? We're here to help.</p>
                    <div class="contact-details">
                        <div class="detail-row"><i class="fas fa-map-marker-alt" style="font-size:1.3rem;"></i> Suite 460, Houston, TX 77024</div>
                        <div class="detail-row"><i class="fas fa-phone-alt"></i> +1 (522) 605-6148</div>
                        <div class="detail-row"><i class="fas fa-envelope"></i> hello@electroscanai.com</div>
                    </div>
                    <div class="chat-badge">
                        <i class="fas fa-comment-dots"></i> Live Chat · We're Online <i class="fas fa-circle" style="font-size:0.6rem; color:#6BCB9E;"></i>
                    </div>
                    <p style="margin-top: 20px;"><i class="fas fa-clock"></i> Support: Mon-Fri 8am - 7pm CST</p>
                </div>
                <div class="contact-right">
                    <form id="luxuryContactForm">
                        <div class="input-group"><input type="text" placeholder="Your Name" id="name" required></div>
                        <div class="input-group"><input type="email" placeholder="Your Email" id="email" required></div>
                        <div class="input-group"><input type="tel" placeholder="Phone Number" id="phone"></div>
                        <div class="input-group"><input type="text" placeholder="Company / Organization"></div>
                        <div class="input-group"><textarea rows="3" placeholder="Your Message" id="msg"></textarea></div>
                        <button type="submit" class="btn-premium" style="width:100%; justify-content:center;"><i class="fas fa-paper-plane"></i> Send Message</button>
                    </form>
                    <p style="font-size:0.7rem; text-align:center; margin-top:16px;">We'll get back within 24 hours</p>
                </div>
            </div>
        </div>

        <div class="container reveal" style="margin-top: 40px;">
            <div style="background: #F1F9F5; border-radius: 48px; padding: 44px 32px; text-align: center;">
                <h3 style="font-size: 1.8rem;">Stay Updated with ElectroScan AI</h3>
                <p style="margin:12px 0 24px;">Get the latest AI electrical insights, case studies, and product updates.</p>
                <div style="display: flex; gap: 12px; max-width: 500px; margin: 0 auto;">
                    <input type="email" id="newsEmail" placeholder="Your email address" style="flex:1; padding:16px 20px; border-radius:60px; border:1px solid #CBE5DC;">
                    <button id="subscribeNewsBtn" class="btn-premium" style="padding: 16px 32px;">Subscribe</button>
                </div>
            </div>
        </div>
    </main>

</body>
</html>