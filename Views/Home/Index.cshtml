@{
    ViewData["Title"] = "Home Page";
}
<main>
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="hero-layout">
                <div class="hero-content reveal">
                    <div class="hero-badge">
                        <i class="fas fa-bolt"></i>
                        AI-Powered Electrical Intelligence
                    </div>
                    <h1>Smarter Scans.<br>Safer Systems.</h1>
                    <p class="hero-description">
                        ElectroScan AI uses advanced artificial intelligence to detect, assess, calculate loads 
                        and generate compliant reports — faster and more accurately than traditional methods.
                    </p>
                    <div class="hero-actions">
                        <a asp-action="Demo" asp-controller="Home" class="btn-primary">
                            <i class="fas fa-play-circle"></i>
                            Watch Demo
                        </a>
                        <a asp-action="Service" asp-controller="Home" class="btn-secondary">
                            <i class="fas fa-chart-line"></i>
                            Explore Services
                        </a>
                    </div>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <span class="stat-number">98%</span>
                            <span class="stat-label">Faster Reporting</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-number">24/7</span>
                            <span class="stat-label">AI Scanning</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-number">NEC+</span>
                            <span class="stat-label">Certified Reports</span>
                        </div>
                    </div>
                </div>
                <div class="hero-visual reveal">
                    <div class="hero-image-wrapper">
                        <img src="~/image/homeheader.jpg" alt="ElectroScan AI Diagnostics" />
                        <div class="hero-image-badge">
                            <i class="fas fa-circle"></i>
                            <span>Intelligent diagnostics · Real-time analytics</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Advantages -->
    <section class="advantages-section">
        <div class="container">
            <div class="section-header text-center reveal">
                <span class="section-tag"><i class="fas fa-bolt"></i> Core Advantages</span>
                <h2>Built for electrical precision</h2>
                <p class="section-subtitle">
                    From inspection to compliance, every workflow is designed to shorten analysis time 
                    and increase confidence on-site.
                </p>
            </div>
            <div class="advantages-grid">
                <div class="advantage-card reveal">
                    <div class="advantage-icon">
                        <i class="fas fa-eye"></i>
                    </div>
                    <h3>AI-Powered Detection</h3>
                    <p>Advanced computer vision identifies thermal anomalies, arc faults, and loose connections with 99% accuracy.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="ai-detection" class="advantage-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="advantage-card reveal" style="transition-delay: 0.1s;">
                    <div class="advantage-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3>Enhance Safety & Compliance</h3>
                    <p>Automated NEC/NFPA reporting, risk mitigation, and real-time compliance dashboards for facility managers.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="safety-compliance" class="advantage-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="advantage-card reveal" style="transition-delay: 0.2s;">
                    <div class="advantage-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h3>Save Time & Reduce Risk</h3>
                    <p>Cut inspection time by 70% while improving fault detection — intelligent load calculations prevent overloads.</p>
                    <a asp-action="Service" asp-controller="Home" asp-fragment="time-risk" class="advantage-link">
                        Learn More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-preview-section">
        <div class="container">
            <div class="about-preview-layout reveal">
                <div class="about-preview-text">
                    <span class="section-tag">About Us</span>
                    <h2>Intelligence That Powers <span class="highlight">Electrical Safety</span></h2>
                    <p>
                        ElectroScan AI is built for electrical professionals, contractors, and facility managers 
                        who demand accuracy, speed, and compliance. Our AI-driven platform simplifies complex 
                        electrical inspections and reporting.
                    </p>
                    <div class="feature-grid">
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>AI-Powered Issue Detection</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Reduce Downtime & Risk</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Accurate Load Calculations</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Improve Operational Safety</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>NEC Compliant Reports</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Cloud-Based & Secure</span>
                        </div>
                    </div>
                    <a asp-action="About" asp-controller="Home" class="btn-secondary">
                        Learn More About Us <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="about-preview-stats">
                    <div class="stats-card">
                        <i class="fas fa-charging-station"></i>
                        <h3>Trusted by 500+ firms</h3>
                        <p>Real-time AI analytics · 24/7 monitoring · Secure</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Smart Solutions -->
    <section class="solutions-section">
        <div class="container">
            <div class="section-header text-center reveal">
                <span class="section-tag"><i class="fas fa-layer-group"></i> Smart Solutions</span>
                <h2>For Electrical Professionals</h2>
            </div>
            <div class="solutions-tabs reveal">
                <span class="solution-pill">AI Scan</span>
                <span class="solution-pill">Load Calculation</span>
                <span class="solution-pill">Safety Reports</span>
                <span class="solution-pill">Compliance Analytics</span>
            </div>
            <div class="solutions-grid">
                <div class="solution-card reveal">
                    <div class="solution-icon">
                        <i class="fas fa-microscope"></i>
                    </div>
                    <h3>AI Scan</h3>
                    <p>Advanced AI detects exact anomalies, potential failures in real-time — predictive maintenance insights.</p>
                    <a asp-action="AI_Scanner" asp-controller="Home" class="btn-primary btn-sm">Learn More →</a>
                </div>
                <div class="solution-card reveal" style="transition-delay: 0.1s;">
                    <div class="solution-icon">
                        <i class="fas fa-weight-hanging"></i>
                    </div>
                    <h3>Load Calculation</h3>
                    <p>Accurate load calculations ensure system reliability, prevent overloads, and optimize performance.</p>
                    <a asp-action="Calculator" asp-controller="Home" class="btn-primary btn-sm">Learn More →</a>
                </div>
                <div class="solution-card reveal" style="transition-delay: 0.2s;">
                    <div class="solution-icon">
                        <i class="fas fa-file-signature"></i>
                    </div>
                    <h3>Safety Reports</h3>
                    <p>Generate NEC-compliant reports with intensity & actionable safety recommendations in seconds.</p>
                    <a asp-action="AI_Scanner" asp-controller="Home" class="btn-primary btn-sm">Learn More →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials-section">
        <div class="container">
            <div class="section-header text-center reveal">
                <span class="section-tag"><i class="fas fa-star"></i> Outcomes</span>
                <h2>Clients love the confidence it brings</h2>
            </div>
            <div class="testimonials-grid">
                <div class="testimonial-card reveal">
                    <div class="testimonial-rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <h3>Faster field decisions</h3>
                    <p>"Before ElectroScan AI, we spent hours validating reports. Now our field team moves with confidence and speed."</p>
                </div>
                <div class="testimonial-card reveal" style="transition-delay: 0.1s;">
                    <div class="testimonial-rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <h3>Clearer compliance</h3>
                    <p>"The risk summaries and recommendations are easy to hand over to clients and internal stakeholders."</p>
                </div>
                <div class="testimonial-card reveal" style="transition-delay: 0.2s;">
                    <div class="testimonial-rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <h3>More reliable oversight</h3>
                    <p>"We can identify probable risks earlier without adding friction to the inspection process."</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing -->
    <section class="pricing-section">
        <div class="container">
            <div class="section-header text-center reveal">
                <span class="section-tag"><i class="fas fa-dollar-sign"></i> Pricing</span>
                <h2>Choose your plan</h2>
                <p class="section-subtitle">
                    A premium operating model for small teams, growing service companies, and larger inspection programs.
                </p>
            </div>
            <div class="pricing-grid">
                <div class="pricing-card reveal">
                    <div class="pricing-icon">
                        <i class="fas fa-seedling"></i>
                    </div>
                    <h3>Starter</h3>
                    <div class="pricing-price">$29 <span>/ month</span></div>
                    <p>Best for individual consultants and early-stage inspection workflows.</p>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> 10 AI scans</li>
                        <li><i class="fas fa-check"></i> Basic report generation</li>
                        <li><i class="fas fa-check"></i> Standard analytics</li>
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn-secondary btn-full">Get Started</a>
                </div>
                <div class="pricing-card featured reveal" style="transition-delay: 0.1s;">
                    <div class="featured-badge">Most Popular</div>
                    <div class="pricing-icon">
                        <i class="fas fa-rocket"></i>
                    </div>
                    <h3>Growth</h3>
                    <div class="pricing-price">$79 <span>/ month</span></div>
                    <p>For service teams that need advanced diagnostics, faster turnaround, and collaboration.</p>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> Unlimited AI scans</li>
                        <li><i class="fas fa-check"></i> Team dashboards</li>
                        <li><i class="fas fa-check"></i> Priority support</li>
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn-primary btn-full">Choose Growth</a>
                </div>
                <div class="pricing-card reveal" style="transition-delay: 0.2s;">
                    <div class="pricing-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <h3>Enterprise</h3>
                    <div class="pricing-price">Custom <span>scaling</span></div>
                    <p>Built for large portfolios and coordinated multi-site electrical operations.</p>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> Advanced workflows</li>
                        <li><i class="fas fa-check"></i> White-label controls</li>
                        <li><i class="fas fa-check"></i> Dedicated onboarding</li>
                    </ul>
                    <a asp-controller="Home" asp-action="Contact" class="btn-secondary btn-full">Talk to Sales</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="contact-section">
        <div class="container">
            <div class="contact-layout reveal">
                <div class="contact-info">
                    <h2>Let's Talk</h2>
                    <p>Have a question or want to schedule a demo? We're here to help.</p>
                    <div class="contact-details">
                        <div class="contact-detail">
                            <i class="fas fa-map-marker-alt"></i>
                            <span>Suite 460, Houston, TX 77024</span>
                        </div>
                        <div class="contact-detail">
                            <i class="fas fa-phone-alt"></i>
                            <span>+1 (522) 605-6148</span>
                        </div>
                        <div class="contact-detail">
                            <i class="fas fa-envelope"></i>
                            <span>hello@electroscanai.com</span>
                        </div>
                    </div>
                    <div class="contact-chat">
                        <i class="fas fa-comment-dots"></i>
                        Live Chat · We're Online <i class="fas fa-circle"></i>
                    </div>
                    <p class="contact-hours"><i class="fas fa-clock"></i> Support: Mon-Fri 8am - 7pm CST</p>
                </div>
                <div class="contact-form-wrapper">
                    <form id="luxuryContactForm">
                        <div class="form-group">
                            <input type="text" placeholder="Your Name" id="name" required />
                        </div>
                        <div class="form-group">
                            <input type="email" placeholder="Your Email" id="email" required />
                        </div>
                        <div class="form-group">
                            <input type="tel" placeholder="Phone Number" id="phone" />
                        </div>
                        <div class="form-group">
                            <input type="text" placeholder="Company / Organization" />
                        </div>
                        <div class="form-group">
                            <textarea rows="3" placeholder="Your Message" id="msg"></textarea>
                        </div>
                        <button type="submit" class="btn-primary btn-full">
                            <i class="fas fa-paper-plane"></i>
                            Send Message
                        </button>
                    </form>
                    <p class="form-note">We'll get back within 24 hours</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter -->
    <section class="newsletter-section">
        <div class="container">
            <div class="newsletter-card reveal">
                <h3>Stay Updated with ElectroScan AI</h3>
                <p>Get the latest AI electrical insights, case studies, and product updates.</p>
                <div class="newsletter-form">
                    <input type="email" id="newsEmail" placeholder="Your email address" />
                    <button id="subscribeNewsBtn" class="btn-primary">Subscribe</button>
                </div>
            </div>
        </div>
    </section>
</main>