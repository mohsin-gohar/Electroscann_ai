<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>AI Scanner | ElectroScan AI — Intelligent Electrical Analysis</title>
    <!-- Google Fonts + premium typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js" defer></script>
</head>
<body>


    <main>
        <div class="scanner-hero">
            <div class="container">
                <div class="hero-tag reveal"><i class="fas fa-microchip"></i> AI-POWERED ANALYSIS</div>
                <h1 class="reveal" style="font-size: 3rem; font-weight: 700; letter-spacing: -0.02em;">Electrical AI Scanner</h1>
                <p class="reveal" style="color: #5A7568; max-width: 600px; margin-top: 16px;">Upload or capture electrical panel images — our AI detects anomalies, loose connections, overload risks, and generates NEC-compliant reports instantly.</p>
            </div>
        </div>

        <div class="container">
            <!-- Two scanner cards: Camera & Upload -->
            <div class="scanner-grid reveal">
                <!-- Camera Card -->
                <div class="scanner-card">
                    <div class="card-header-premium">
                        <h4 style="margin:0;"><i class="fas fa-camera" style="margin-right: 12px;"></i>Live Camera Scan</h4>
                    </div>
                    <div class="card-body-premium">
                        <div class="camera-preview-area" id="cameraPreviewArea">
                            <div style="text-align: center; color: rgba(255,255,255,0.7);">
                                <i class="fas fa-video" style="font-size: 3rem; margin-bottom: 12px; display: block;"></i>
                                <p>Camera preview ready</p>
                                <button class="btn-premium btn-orange" id="startCameraBtn" style="padding: 10px 24px; font-size: 0.85rem;"><span class="blink-dot"></span> Start Camera</button>
                            </div>
                        </div>
                        <div id="cameraLoading" class="loading-overlay">
                            <div class="spinner-ring"></div>
                            <p style="color: var(--moss); font-weight: 500;">AI analyzing electrical components...</p>
                        </div>
                    </div>
                </div>

                <!-- Upload Card -->
                <div class="scanner-card">
                    <div class="card-header-premium">
                        <h4 style="margin:0;"><i class="fas fa-upload" style="margin-right: 12px;"></i>Upload Image</h4>
                    </div>
                    <div class="card-body-premium">
                        <div class="drop-zone" id="dropZone">
                            <i class="fas fa-cloud-upload-alt" style="font-size: 2.5rem; color: var(--moss); margin-bottom: 12px; display: block;"></i>
                            <p style="font-weight: 500;">Drag & drop electrical panel image</p>
                            <p style="color: #8AA79A; font-size: 0.8rem;">or</p>
                            <button class="btn-premium btn-orange" id="uploadBtn" style="padding: 10px 28px; font-size: 0.85rem;"><i class="fas fa-folder-open"></i> Browse Files</button>
                            <input type="file" id="fileInput" accept="image/*" style="display: none;">
                        </div>
                        <div id="uploadLoading" class="loading-overlay">
                            <div class="spinner-ring"></div>
                            <p style="color: var(--moss);">Processing image with AI vision...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results Panel (hidden initially) -->
            <div id="resultsPanel" class="results-panel reveal">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 28px;">
                    <h3 style="font-weight: 700;"><i class="fas fa-clipboard-list" style="color: var(--moss); margin-right: 12px;"></i>Analysis Report</h3>
                    <span style="background: #EFF9F4; padding: 6px 16px; border-radius: 40px; font-size: 0.8rem;">Scan ID: #ESC-2026-0218</span>
                </div>

                <div style="display: flex; flex-wrap: wrap; gap: 24px; margin-bottom: 36px;">
                    <div style="flex: 1; background: #F9FDFB; border-radius: 24px; padding: 20px; text-align: center;">
                        <div class="progress-bar-custom" style="width: 100%; margin-bottom: 12px;">
                            <div class="progress-fill" id="confidenceFill" style="width: 0%;"></div>
                        </div>
                        <h2 id="confidenceScore" style="font-size: 2rem; font-weight: 700;">0%</h2>
                        <p style="color: var(--text-muted);">Confidence Score</p>
                    </div>
                    <div style="flex: 1; background: #F9FDFB; border-radius: 24px; padding: 20px; text-align: center;">
                        <h2 id="safetyScore" style="font-size: 2rem; font-weight: 700; color: var(--pine);">0</h2>
                        <p style="color: var(--text-muted);">Safety Score /100</p>
                    </div>
                    <div style="flex: 1; background: #F9FDFB; border-radius: 24px; padding: 20px; text-align: center;">
                        <span id="riskBadge" class="risk-badge risk-medium">—</span>
                        <p style="margin-top: 12px; color: var(--text-muted);">Risk Level</p>
                    </div>
                </div>

                <h5 style="margin-bottom: 16px;"><i class="fas fa-exclamation-triangle" style="color: var(--electric-orange);"></i> Detected Anomalies</h5>
                <div id="issuesList"></div>

                <div style="margin-top: 32px; text-align: center;">
                    <button class="btn-premium" id="downloadReportBtn" style="background: var(--pine);"><i class="fas fa-download"></i> Download NEC Report</button>
                    <button class="btn-premium btn-outline-premium" style="margin-left: 12px; background: transparent; border: 1.5px solid var(--border-light);" id="newScanBtn"><i class="fas fa-redo-alt"></i> New Scan</button>
                </div>
            </div>
        </div>
    </main>

    <div id="toastMsg" class="toast-message">
        <i class="fas fa-check-circle" style="color: var(--moss); font-size: 1.3rem;"></i>
        <span id="toastText">Analysis complete</span>
    </div>

    <!-- Interactive script for webcam and drag-and-drop upload -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let stream = null;
            const startCameraBtn = document.getElementById("startCameraBtn");
            const cameraPreviewArea = document.getElementById("cameraPreviewArea");
            const cameraLoading = document.getElementById("cameraLoading");
            const resultsPanel = document.getElementById("resultsPanel");

            const fileInput = document.getElementById("fileInput");
            const uploadBtn = document.getElementById("uploadBtn");
            const dropZone = document.getElementById("dropZone");
            const uploadLoading = document.getElementById("uploadLoading");

            const confidenceFill = document.getElementById("confidenceFill");
            const confidenceScore = document.getElementById("confidenceScore");
            const safetyScore = document.getElementById("safetyScore");
            const riskBadge = document.getElementById("riskBadge");
            const issuesList = document.getElementById("issuesList");

            const newScanBtn = document.getElementById("newScanBtn");
            const downloadReportBtn = document.getElementById("downloadReportBtn");

            // Web Camera Implementation
            if (startCameraBtn) {
                startCameraBtn.addEventListener("click", async function () {
                    try {
                        // Request user camera stream
                        stream = await navigator.mediaDevices.getUserMedia({
                            video: { facingMode: "environment" },
                            audio: false
                        });

                        // Set up video preview inside preview area
                        cameraPreviewArea.innerHTML = `
                            <div style="position: relative; width: 100%; height: 100%; min-height: 250px; overflow: hidden; border-radius: 16px;">
                                <video id="webcamVideo" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover; background: #000;"></video>
                                <div style="position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; z-index: 10;">
                                    <button class="btn-premium" id="captureFrameBtn" style="background: #e67e22; border: none; padding: 10px 20px; font-weight: 600;"><i class="fas fa-camera"></i> Capture Frame</button>
                                    <button class="btn-premium" id="stopCameraBtn" style="background: rgba(0,0,0,0.6); border: none; padding: 10px 20px;"><i class="fas fa-times"></i> Stop</button>
                                </div>
                            </div>
                        `;

                        const video = document.getElementById("webcamVideo");
                        video.srcObject = stream;

                        // Capture frame action
                        document.getElementById("captureFrameBtn").addEventListener("click", function () {
                            // Play shutter sound or effect
                            showToast("Capturing wire frame...");
                            cameraLoading.style.display = "flex";

                            setTimeout(() => {
                                stopVideoStream();
                                runSimulationAnalysis(true);
                            }, 1500);
                        });

                        // Stop action
                        document.getElementById("stopCameraBtn").addEventListener("click", function () {
                            stopVideoStream();
                            resetCameraArea();
                        });

                    } catch (err) {
                        console.error("Camera access error:", err);
                        showToast("Error: Could not access web camera. Please check permissions.", true);
                    }
                });
            }

            function stopVideoStream() {
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                    stream = null;
                }
            }

            function resetCameraArea() {
                cameraPreviewArea.innerHTML = `
                    <div style="text-align: center; color: rgba(255,255,255,0.7);">
                        <i class="fas fa-video" style="font-size: 3rem; margin-bottom: 12px; display: block;"></i>
                        <p>Camera preview ready</p>
                        <button class="btn-premium btn-orange" id="startCameraBtn" style="padding: 10px 24px; font-size: 0.85rem;"><span class="blink-dot"></span> Start Camera</button>
                    </div>
                `;
                // Re-bind click event
                const newBtn = document.getElementById("startCameraBtn");
                newBtn.addEventListener("click", startCameraBtn.click);
            }

            // Drag and Drop Upload Implementation
            if (uploadBtn && fileInput) {
                uploadBtn.addEventListener("click", function () {
                    fileInput.click();
                });

                fileInput.addEventListener("change", function (e) {
                    if (e.target.files.length > 0) {
                        handleFileSelection(e.target.files[0]);
                    }
                });
            }

            if (dropZone) {
                dropZone.addEventListener("dragover", function (e) {
                    e.preventDefault();
                    dropZone.style.borderColor = "var(--primary)";
                    dropZone.style.background = "rgba(31, 138, 107, 0.05)";
                });

                ["dragleave", "drop"].forEach(eventName => {
                    dropZone.addEventListener(eventName, function () {
                        dropZone.style.borderColor = "var(--border-light)";
                        dropZone.style.background = "transparent";
                    });
                });

                dropZone.addEventListener("drop", function (e) {
                    e.preventDefault();
                    if (e.dataTransfer.files.length > 0) {
                        handleFileSelection(e.dataTransfer.files[0]);
                    }
                });
            }

            function handleFileSelection(file) {
                if (!file.type.startsWith("image/")) {
                    showToast("Please upload a valid image file.", true);
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (ev) {
                    dropZone.innerHTML = `
                        <div style="width: 100%; max-height: 220px; overflow: hidden; border-radius: 12px;">
                            <img src="${ev.target.result}" style="width: 100%; height: 100%; object-fit: contain; max-height: 220px;">
                            <p style="margin-top:10px; font-size:0.8rem; color:#8AA79A;">${file.name}</p>
                        </div>
                    `;
                    uploadLoading.style.display = "flex";

                    setTimeout(() => {
                        runSimulationAnalysis(false);
                    }, 1800);
                };
                reader.readAsDataURL(file);
            }

            // Simulated AI Scan Analysis Results Generation
            function runSimulationAnalysis(isCamera) {
                if (isCamera) {
                    cameraLoading.style.display = "none";
                } else {
                    uploadLoading.style.display = "none";
                }

                // Make results visible
                resultsPanel.style.display = "block";
                resultsPanel.scrollIntoView({ behavior: "smooth" });

                // Random safety values & risk status simulation
                const confidence = Math.floor(Math.random() * 15) + 82; // 82 - 97%
                const safety = Math.floor(Math.random() * 25) + 70; // 70 - 95
                
                let riskText = "LOW";
                let riskClass = "risk-low";
                let anomalies = [];

                if (safety < 75) {
                    riskText = "HIGH";
                    riskClass = "risk-high";
                    anomalies = [
                        { type: "Thermal Anomaly", detail: "Overheated main breaker connection detected at phase A (92°C)." },
                        { type: "NEC Code Violation", detail: "Improper cable routing & open wiring joints outside secondary junction box." }
                    ];
                } else if (safety < 88) {
                    riskText = "MEDIUM";
                    riskClass = "risk-medium";
                    anomalies = [
                        { type: "Junction Box Dust", detail: "Significant dust & debris accumulation inside distribution panel cabinet." }
                    ];
                } else {
                    riskText = "LOW";
                    riskClass = "risk-low";
                    anomalies = [];
                }

                // Set values to DOM
                confidenceScore.innerText = `${confidence}%`;
                confidenceFill.style.width = `${confidence}%`;
                safetyScore.innerText = safety;
                
                riskBadge.innerText = riskText;
                riskBadge.className = `risk-badge ${riskClass}`;

                // Populate anomalies list
                if (anomalies.length === 0) {
                    issuesList.innerHTML = `
                        <div style="background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 12px; padding: 16px; display: flex; align-items: center; gap: 10px; color: #166534;">
                            <i class="fas fa-check-circle" style="font-size: 1.2rem;"></i>
                            <span>No major electrical anomalies or compliance violations detected. Your system meets safety parameters.</span>
                        </div>
                    `;
                } else {
                    issuesList.innerHTML = anomalies.map(issue => `
                        <div style="background: #FFFBEB; border: 1px solid #FDE68A; border-radius: 12px; padding: 16px; margin-bottom: 10px; display: flex; align-items: flex-start; gap: 12px;">
                            <i class="fas fa-exclamation-triangle" style="color: #D97706; font-size: 1.2rem; margin-top: 2px;"></i>
                            <div>
                                <strong style="color: #92400E; display: block; font-size: 0.9rem;">${issue.type}</strong>
                                <span style="color: #B45309; font-size: 0.82rem; line-height:1.4; display:block; margin-top:2px;">${issue.detail}</span>
                            </div>
                        </div>
                    `).join("");
                }

                showToast("AI Diagnostic Report Generated Successfully! 🎉");
            }

            // New Scan / Redo button action
            if (newScanBtn) {
                newScanBtn.addEventListener("click", function () {
                    resultsPanel.style.display = "none";
                    resetCameraArea();
                    
                    // Reset upload area
                    dropZone.innerHTML = `
                        <i class="fas fa-cloud-upload-alt" style="font-size: 2.5rem; color: var(--moss); margin-bottom: 12px; display: block;"></i>
                        <p style="font-weight: 500;">Drag & drop electrical panel image</p>
                        <p style="color: #8AA79A; font-size: 0.8rem;">or</p>
                        <button class="btn-premium btn-orange" id="uploadBtn" style="padding: 10px 28px; font-size: 0.85rem;"><i class="fas fa-folder-open"></i> Browse Files</button>
                    `;
                    // Re-bind browse click event
                    document.getElementById("uploadBtn").addEventListener("click", function () {
                        fileInput.click();
                    });
                    
                    showToast("Scanner reset. Ready for new input.");
                });
            }

            // Download PDF Report action
            if (downloadReportBtn) {
                downloadReportBtn.addEventListener("click", function () {
                    showToast("Preparing PDF generation...");
                    
                    // Trigger native print flow styled for report
                    window.print();
                });
            }

            function showToast(msg, isError = false) {
                const toast = document.getElementById("toastMsg");
                const text = document.getElementById("toastText");
                const icon = toast.querySelector("i");
                
                text.textContent = msg;
                if (isError) {
                    icon.className = "fas fa-exclamation-circle";
                    toast.style.background = "#991B1B";
                } else {
                    icon.className = "fas fa-check-circle";
                    toast.style.background = "#0B2B26";
                }
                
                toast.style.display = "flex";
                setTimeout(() => {
                    toast.style.display = "none";
                }, 3000);
            }
        });
    </script>
</body>
</html>