<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Wire & Load Calculator | ElectroScan AI — Smart Electrical Calculations</title>
    <!-- Google Fonts + premium typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js" defer></script>
</head>
<body>

    <main>
        <div class="calculator-hero">
            <div class="container">
                <div class="hero-tag reveal"><i class="fas fa-calculator"></i> SMART CALCULATIONS</div>
                <h1 class="reveal" style="font-size: 3rem; font-weight: 700; letter-spacing: -0.02em;">Wire & Load Calculator</h1>
                <p class="reveal" style="color: #5A7568; max-width: 550px; margin: 16px auto 0;">NEC-compliant calculations for wire sizing, load capacity, breaker recommendations, and safety guidelines.</p>
            </div>
        </div>

        <div class="container calculator-grid reveal">
            <!-- Input Panel -->
            <div class="input-card">
                <div class="card-header-premium">
                    <h4 style="margin:0;"><i class="fas fa-ruler-combined" style="margin-right: 12px;"></i>Room Specifications</h4>
                </div>
                <div class="card-body-premium">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 20px; margin-bottom: 32px;">
                        <div>
                            <label>Length (ft)</label>
                            <input type="number" id="roomLength" value="14" step="1" oninput="updateCalculation()">
                        </div>
                        <div>
                            <label>Width (ft)</label>
                            <input type="number" id="roomWidth" value="12" step="1" oninput="updateCalculation()">
                        </div>
                        <div>
                            <label>Height (ft)</label>
                            <input type="number" id="roomHeight" value="9" step="1" oninput="updateCalculation()">
                        </div>
                    </div>

                    <h5 style="margin-bottom: 20px;"><i class="fas fa-plug" style="color: var(--moss); margin-right: 10px;"></i>Electrical Fixtures & Loads</h5>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 18px;">
                        <div class="counter-group">
                            <i class="fas fa-lightbulb" style="color: var(--moss);"></i>
                            <div class="counter-value" id="lightVal">6</div>
                            <button class="counter-btn" onclick="modifyCounter('lights', -1)">−</button>
                            <button class="counter-btn" onclick="modifyCounter('lights', 1)">+</button>
                            <div style="font-size: 0.7rem; margin-top: 8px;">Lights (60W each)</div>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-fan"></i>
                            <div class="counter-value" id="fanVal">2</div>
                            <button class="counter-btn" onclick="modifyCounter('fans', -1)">−</button>
                            <button class="counter-btn" onclick="modifyCounter('fans', 1)">+</button>
                            <div style="font-size: 0.7rem;">Fans (80W)</div>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-plug"></i>
                            <div class="counter-value" id="socketVal">6</div>
                            <button class="counter-btn" onclick="modifyCounter('sockets', -1)">−</button>
                            <button class="counter-btn" onclick="modifyCounter('sockets', 1)">+</button>
                            <div style="font-size: 0.7rem;">Sockets (150W)</div>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-wind"></i>
                            <div class="counter-value" id="acVal">1</div>
                            <button class="counter-btn" onclick="modifyCounter('ac', -1)">−</button>
                            <button class="counter-btn" onclick="modifyCounter('ac', 1)">+</button>
                            <div style="font-size: 0.7rem;">AC Units (2000W)</div>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-industry"></i>
                            <div class="counter-value" id="heavyVal">0</div>
                            <button class="counter-btn" onclick="modifyCounter('heavy', -1)">−</button>
                            <button class="counter-btn" onclick="modifyCounter('heavy', 1)">+</button>
                            <div style="font-size: 0.7rem;">Heavy Loads (3000W)</div>
                        </div>
                    </div>

                    <div style="margin-top: 28px; text-align: center;">
                        <button class="btn-premium btn-orange" id="calculateBtn"><i class="fas fa-calculator"></i> Calculate Now</button>
                    </div>
                </div>
            </div>

            <!-- Results Panel -->
            <div class="result-card">
                <h4 style="margin-bottom: 16px;"><i class="fas fa-chart-line" style="color: var(--moss); margin-right: 8px;"></i>Calculation Results</h4>
                <div class="result-item">
                    <span class="result-label">Total Wire Length</span>
                    <span class="result-value" id="wireLengthDisplay">0 m</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Recommended Wire Gauge</span>
                    <span class="result-value" id="wireGaugeDisplay">12 AWG</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Total Electrical Load</span>
                    <span class="result-value" id="loadDisplay">0 W</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Current (Amps)</span>
                    <span class="result-value" id="currentDisplay">0 A</span>
                </div>
                <div class="result-item">
                    <span class="result-label">MCB / Breaker Rating</span>
                    <span class="result-value" id="breakerDisplay">20 A</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Room Area</span>
                    <span class="result-value" id="areaDisplay">0 sq ft</span>
                </div>

                <div class="warning-box" id="safetyBox">
                    <i class="fas fa-shield-alt" style="color: var(--electric-orange); font-size: 1.3rem; float: left; margin-right: 14px;"></i>
                    <div id="safetyMessage" style="font-size: 0.85rem; color: #4a3b2a;">Adjust fixture counts to see safety recommendations.</div>
                </div>
            </div>
        </div>
    </main>

    <div id="toastMsg" class="toast-msg">
        <i class="fas fa-check-circle" style="color: var(--electric-green, #00D68F);"></i>
        <span id="toastText">Calculation updated</span>
    </div>

</body>
</html>