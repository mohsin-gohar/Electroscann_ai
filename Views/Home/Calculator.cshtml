@model Electroscann_ai.Models.ViewModels.WireCalculatorViewModel
@{
    ViewData["Title"] = "Wire & Load Calculator";
}

<div class="calculator-hero">
    <div class="container">
        <div class="calculator-hero-content reveal">
            <div class="hero-badge">
                <i class="fas fa-calculator"></i>
                SMART CALCULATIONS
            </div>
            <h1>Wire &amp; Load Calculator</h1>
            <p>
                NEC-compliant calculations for wire sizing, load capacity, breaker recommendations, 
                and safety guidelines.
            </p>
        </div>
    </div>
</div>

<div class="container" style="max-width: 1100px;">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">
            @TempData["Info"]
            <a asp-action="Login" asp-controller="Account" class="alert-link">Sign in</a>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <form asp-action="Calculator" asp-controller="Home" method="post" id="calculatorForm"
          data-has-result="@(Model.HasResult ? "true" : "false")">
        @Html.AntiForgeryToken()

        <div class="calculator-layout reveal">
            <!-- Input Panel -->
            <div class="calculator-input">
                <div class="input-panel-header">
                    <h4><i class="fas fa-ruler-combined"></i> Room Specifications</h4>
                </div>
                <div class="input-panel-body">
                    <div class="input-row">
                        <div class="input-group">
                            <label asp-for="RoomLength"></label>
                            <input asp-for="RoomLength" type="number" id="roomLength" step="1" class="form-control" />
                            <span asp-validation-for="RoomLength" class="text-danger"></span>
                        </div>
                        <div class="input-group">
                            <label asp-for="RoomWidth"></label>
                            <input asp-for="RoomWidth" type="number" id="roomWidth" step="1" class="form-control" />
                            <span asp-validation-for="RoomWidth" class="text-danger"></span>
                        </div>
                        <div class="input-group">
                            <label asp-for="RoomHeight"></label>
                            <input asp-for="RoomHeight" type="number" id="roomHeight" step="1" class="form-control" />
                            <span asp-validation-for="RoomHeight" class="text-danger"></span>
                        </div>
                    </div>

                    <h5 class="fixtures-title">
                        <i class="fas fa-plug"></i>
                        Electrical Fixtures &amp; Loads
                    </h5>

                    <input type="hidden" asp-for="Lights" id="lightsInput" />
                    <input type="hidden" asp-for="Fans" id="fansInput" />
                    <input type="hidden" asp-for="Sockets" id="socketsInput" />
                    <input type="hidden" asp-for="AcUnits" id="acInput" />
                    <input type="hidden" asp-for="HeavyLoads" id="heavyInput" />

                    <div class="counter-grid">
                        <div class="counter-group">
                            <i class="fas fa-lightbulb"></i>
                            <div class="counter-value" id="lightVal">@Model.Lights</div>
                            <div class="counter-controls">
                                <button type="button" class="counter-btn" onclick="modifyCounter('lights', -1)">−</button>
                                <button type="button" class="counter-btn" onclick="modifyCounter('lights', 1)">+</button>
                            </div>
                            <span class="counter-label">Lights (60W)</span>
                            <span asp-validation-for="Lights" class="text-danger"></span>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-fan"></i>
                            <div class="counter-value" id="fanVal">@Model.Fans</div>
                            <div class="counter-controls">
                                <button type="button" class="counter-btn" onclick="modifyCounter('fans', -1)">−</button>
                                <button type="button" class="counter-btn" onclick="modifyCounter('fans', 1)">+</button>
                            </div>
                            <span class="counter-label">Fans (80W)</span>
                            <span asp-validation-for="Fans" class="text-danger"></span>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-plug"></i>
                            <div class="counter-value" id="socketVal">@Model.Sockets</div>
                            <div class="counter-controls">
                                <button type="button" class="counter-btn" onclick="modifyCounter('sockets', -1)">−</button>
                                <button type="button" class="counter-btn" onclick="modifyCounter('sockets', 1)">+</button>
                            </div>
                            <span class="counter-label">Sockets (150W)</span>
                            <span asp-validation-for="Sockets" class="text-danger"></span>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-wind"></i>
                            <div class="counter-value" id="acVal">@Model.AcUnits</div>
                            <div class="counter-controls">
                                <button type="button" class="counter-btn" onclick="modifyCounter('ac', -1)">−</button>
                                <button type="button" class="counter-btn" onclick="modifyCounter('ac', 1)">+</button>
                            </div>
                            <span class="counter-label">AC Units (2000W)</span>
                            <span asp-validation-for="AcUnits" class="text-danger"></span>
                        </div>
                        <div class="counter-group">
                            <i class="fas fa-industry"></i>
                            <div class="counter-value" id="heavyVal">@Model.HeavyLoads</div>
                            <div class="counter-controls">
                                <button type="button" class="counter-btn" onclick="modifyCounter('heavy', -1)">−</button>
                                <button type="button" class="counter-btn" onclick="modifyCounter('heavy', 1)">+</button>
                            </div>
                            <span class="counter-label">Heavy Loads (3000W)</span>
                            <span asp-validation-for="HeavyLoads" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="calculator-actions">
                        <button type="submit" class="btn-primary btn-orange" id="calculateBtn">
                            <i class="fas fa-calculator"></i>
                            Calculate Now
                        </button>
                        @if (!(User.Identity?.IsAuthenticated ?? false))
                        {
                            <p class="guest-note">
                                Guests can calculate freely.
                                <a asp-action="Login" asp-controller="Account">Sign in</a> to save results.
                            </p>
                        }
                    </div>
                </div>
            </div>

            <!-- Results Panel -->
            <div class="calculator-results">
                <h4><i class="fas fa-chart-line"></i> Calculation Results</h4>
                <div class="result-item">
                    <span class="result-label">Total Wire Length</span>
                    <span class="result-value" id="wireLengthDisplay">@(Model.HasResult ? $"{Model.Distance:0} m" : "0 m")</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Recommended Wire Gauge</span>
                    <span class="result-value" id="wireGaugeDisplay">@(Model.HasResult ? Model.WireSize : "12 AWG")</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Total Electrical Load</span>
                    <span class="result-value" id="loadDisplay">@(Model.HasResult ? $"{Model.Load:N0} W" : "0 W")</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Current (Amps)</span>
                    <span class="result-value" id="currentDisplay">@(Model.HasResult ? $"{Model.CurrentAmps:0.#} A" : "0 A")</span>
                </div>
                <div class="result-item">
                    <span class="result-label">MCB / Breaker Rating</span>
                    <span class="result-value" id="breakerDisplay">@(Model.HasResult ? Model.BreakerRating : "20 A")</span>
                </div>
                <div class="result-item">
                    <span class="result-label">Room Area</span>
                    <span class="result-value" id="areaDisplay">@(Model.HasResult ? $"{Model.RoomArea:0.#} sq ft" : "0 sq ft")</span>
                </div>

                <div class="safety-warning" id="safetyBox">
                    <i class="fas fa-shield-alt"></i>
                    <div id="safetyMessage">
                        @(Model.HasResult ? Model.SafetyMessage : "Adjust fixture counts and click Calculate Now.")
                    </div>
                </div>
            </div>
        </div>
    </form>

    <!-- History -->
    @if (User.Identity?.IsAuthenticated == true && Model.RecentCalculations != null)
    {
        <div class="history-panel reveal">
            <div class="history-header">
                <h4><i class="fas fa-history"></i> Your Last 5 Calculations</h4>
            </div>
            <div class="history-body">
                @if (Model.RecentCalculations.Count == 0)
                {
                    <p class="empty-state">No saved calculations yet. Run Calculate Now to save your first result.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="history-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Load</th>
                                    <th>Distance</th>
                                    <th>Wire Size</th>
                                    <th>Summary</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.RecentCalculations)
                                {
                                    <tr>
                                        <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                                        <td>@item.Load.ToString("N0") W</td>
                                        <td>@item.Distance.ToString("0") m</td>
                                        <td>@item.WireSize</td>
                                        <td class="history-summary">@item.Result</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}